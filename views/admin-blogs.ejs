<div id="addBlogModal" class="modal">
    <div class="modal-content" style="max-width: 800px;">
        <span class="close" onclick="closeModal('addBlogModal')">&times;</span>
        <h4>Add New Blog</h4>
        <form id="addBlogForm" enctype="multipart/form-data">
            <div class="grid grid-cols-2 gap-4">
                <!-- Left Column -->
                <div>
                    <div class="form-group">
                        <label for="blogTitle">Title *</label>
                        <input type="text" id="blogTitle" name="title" class="w-full" required>
                    </div>

                    <div class="form-group">
                        <label for="blogSlug">Slug</label>
                        <input type="text" id="blogSlug" name="slug" class="w-full">
                        <small class="text-gray-500">Auto-generated from title if empty</small>
                    </div>

                    <div class="form-group">
                        <label for="blogExcerpt">Excerpt</label>
                        <textarea id="blogExcerpt" name="excerpt" class="w-full" rows="2" maxlength="200"></textarea>
                        <small class="text-gray-500">Brief summary (max 200 characters)</small>
                    </div>

                    <div class="form-group">
                        <label for="blogStatus">Status</label>
                        <select id="blogStatus" name="status" class="w-full">
                            <option value="draft">Draft</option>
                            <option value="published">Published</option>
                            <option value="archived">Archived</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="blogCategory">Category</label>
                        <input type="text" id="blogCategory" name="category" class="w-full" list="categoriesList">
                        <datalist id="categoriesList"></datalist>
                    </div>

                    <div class="form-group">
                        <label for="blogTags">Tags (comma separated)</label>
                        <input type="text" id="blogTags" name="tags" class="w-full" placeholder="e.g. beauty, skincare, health">
                    </div>

                    <div class="form-group">
                        <label for="blogFeatured">Featured Post</label>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="blogFeatured" name="featured" value="true">
                            <span class="text-sm">Mark as featured</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="blogPublishedAt">Publish Date</label>
                        <input type="datetime-local" id="blogPublishedAt" name="publishedAt" class="w-full">
                    </div>
                </div>

                <!-- Right Column -->
                <div>
                    <div class="form-group">
                        <label for="blogFeaturedImage">Featured Image</label>
                        <input type="file" id="blogFeaturedImage" name="featuredImage" accept="image/*" class="w-full">
                        <small class="text-gray-500">Main blog image (max 5MB)</small>
                        <div id="featuredImagePreview" class="mt-2"></div>
                    </div>

                    <div class="form-group">
                        <label for="blogGalleryImages">Gallery Images</label>
                        <input type="file" id="blogGalleryImages" name="gallery" accept="image/*" multiple class="w-full">
                        <small class="text-gray-500">Additional images (max 10, 5MB each)</small>
                        <div id="galleryPreview" class="mt-2 grid grid-cols-3 gap-2"></div>
                    </div>

                    <div class="form-group">
                        <label for="blogAuthorName">Author Name</label>
                        <input type="text" id="blogAuthorName" name="author[name]" class="w-full">
                    </div>

                    <div class="form-group">
                        <label for="blogAuthorBio">Author Bio</label>
                        <textarea id="blogAuthorBio" name="author[bio]" class="w-full" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <!-- Rich Text Editor -->
            <div class="form-group mt-4">
                <label for="editor">Content *</label>
                <div id="editor" style="height: 400px;"></div>
                <textarea id="blogContentHidden" name="content" style="display: none;"></textarea>
            </div>

            <!-- SEO Section -->
            <div class="border-t pt-4 mt-4">
                <h5 class="font-medium mb-3">SEO Settings</h5>
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-group">
                        <label for="blogMetaTitle">Meta Title</label>
                        <input type="text" id="blogMetaTitle" name="metaTitle" class="w-full">
                    </div>
                    <div class="form-group">
                        <label for="blogMetaKeywords">Meta Keywords</label>
                        <input type="text" id="blogMetaKeywords" name="metaKeywords" class="w-full" placeholder="comma separated">
                    </div>
                </div>
                <div class="form-group">
                    <label for="blogMetaDescription">Meta Description</label>
                    <textarea id="blogMetaDescription" name="metaDescription" class="w-full" rows="2" maxlength="160"></textarea>
                    <small class="text-gray-500">Max 160 characters for search engines</small>
                </div>
            </div>

            <!-- Custom Fields (Optional) -->
            <div class="border-t pt-4 mt-4">
                <div class="flex justify-between items-center mb-3">
                    <h5 class="font-medium">Custom Fields</h5>
                    <button type="button" class="text-sm text-blue-600" onclick="addCustomField()">+ Add Field</button>
                </div>
                <div id="customFieldsContainer"></div>
            </div>

            <div class="flex gap-4 mt-6">
                <button type="submit" class="tf-button style-1 flex-1">Create Blog</button>
