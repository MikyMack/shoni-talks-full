            </div>

            <!-- Rich Text Editor -->
            <div class="form-group mt-4">
                <label for="editBlogContent">Content *</label>
                <div id="editEditorToolbar" class="border border-gray-300 rounded-t-lg p-2 bg-gray-50">
                    <button type="button" class="editor-btn" onclick="formatEditText('bold')"><b>B</b></button>
                    <button type="button" class="editor-btn" onclick="formatEditText('italic')"><i>I</i></button>
                    <button type="button" class="editor-btn" onclick="formatEditText('underline')"><u>U</u></button>
                    <button type="button" class="editor-btn" onclick="formatEditText('insertUnorderedList')">• List</button>
                    <button type="button" class="editor-btn" onclick="formatEditText('insertOrderedList')">1. List</button>
                    <button type="button" class="editor-btn" onclick="insertEditImage()">📷 Image</button>
                    <button type="button" class="editor-btn" onclick="formatEditText('createLink', prompt('Enter URL:'))">🔗 Link</button>
