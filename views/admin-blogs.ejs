                <div id="editBlogContent" contenteditable="true" class="w-full h-64 border border-gray-300 border-t-0 rounded-b-lg p-4 overflow-auto"></div>
                <textarea id="editBlogContentHidden" name="content" style="display: none;"></textarea>
            </div>

            <!-- SEO Section -->
            <div class="border-t pt-4 mt-4">
                <h5 class="font-medium mb-3">SEO Settings</h5>
                <div class="grid grid-cols-2 gap-4">
                    <div class="form-group">
                        <label for="editBlogMetaTitle">Meta Title</label>
                        <input type="text" id="editBlogMetaTitle" name="metaTitle" class="w-full">
                    </div>
                    <div class="form-group">
                        <label for="editBlogMetaKeywords">Meta Keywords</label>
                        <input type="text" id="editBlogMetaKeywords" name="metaKeywords" class="w-full">
                    </div>
                </div>
                <div class="form-group">
                    <label for="editBlogMetaDescription">Meta Description</label>
                    <textarea id="editBlogMetaDescription" name="metaDescription" class="w-full" rows="2" maxlength="160"></textarea>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="border-t pt-4 mt-4">
                <h5 class="font-medium mb-3">Statistics</h5>
                <div class="grid grid-cols-4 gap-4">
                    <div class="text-center p-3 bg-gray-50 rounded">
                        <div class="text-2xl font-bold" id="editBlogViews">0</div>
                        <div class="text-sm text-gray-600">Views</div>
                    </div>
                    <div class="text-center p-3 bg-gray-50 rounded">
                        <div class="text-2xl font-bold" id="editBlogLikes">0</div>
                        <div class="text-sm text-gray-600">Likes</div>
                    </div>
                    <div class="text-center p-3 bg-gray-50 rounded">
                        <div class="text-2xl font-bold" id="editBlogShares">0</div>
                        <div class="text-sm text-gray-600">Shares</div>
                    </div>
                    <div class="text-center p-3 bg-gray-50 rounded">
                        <div class="text-2xl font-bold" id="editBlogReadingTime">0</div>
                        <div class="text-sm text-gray-600">min read</div>
                    </div>
                </div>
            </div>

            <div class="flex gap-4 mt-6">
                <button type="submit" class="tf-button style-1 flex-1">Update Blog</button>
                <button type="button" class="tf-button style-3 flex-1" onclick="previewBlog()">Preview</button>
                <button type="button" class="tf-button style-2 flex-1" onclick="closeModal('editBlogModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Preview Modal -->
<div id="previewModal" class="modal">
    <div class="modal-content" style="max-width: 900px;">
        <span class="close" onclick="closeModal('previewModal')">&times;</span>
        <h4>Blog Preview</h4>
        <div id="blogPreviewContent" class="mt-4 p-4 border rounded-lg"></div>
    </div>
</div>
                                <script>
                                    let blogs = [];
                                    let currentPage = 1;
                                    let totalPages = 1;
                                    let categories = [];
                                    let blogStats = {};
                                    let searchTimeout;
                                    let quill;
                                
                                    // Initialize on DOM ready
                                    document.addEventListener("DOMContentLoaded", function () {
                                        fetchBlogStats();
                                        fetchCategories();
                                        fetchBlogs();
                                        setupBlogFormHandlers();
                                        setupImagePreviews();
                                        initializeQuill(); // Initialize Quill properly
                                        initializeEditors();
                                    });
                                
                                    // ==================== CUSTOM FIELDS FUNCTIONS ====================
                                    function addCustomField() {
                                        const container = document.getElementById('customFieldsContainer');
                                        const fieldCount = container.children.length;
                                        const fieldId = `custom_field_${fieldCount}`;
                                        
                                        const fieldHtml = `
                                            <div class="custom-field-item grid grid-cols-12 gap-2 mb-2" id="${fieldId}">
                                                <div class="col-span-5">
                                                    <input type="text" name="customFields[${fieldCount}][key]" placeholder="Field Name" 
                                                           class="w-full p-2 border rounded text-sm">
                                                </div>
                                                <div class="col-span-5">
                                                    <input type="text" name="customFields[${fieldCount}][value]" placeholder="Field Value" 
                                                           class="w-full p-2 border rounded text-sm">
                                                </div>
                                                <div class="col-span-2">
                                                    <button type="button" onclick="removeCustomField('${fieldId}')" 
                                                            class="w-full p-2 bg-red-100 text-red-600 rounded hover:bg-red-200">
                                                        <i class="icon-trash-2"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        `;
                                        
                                        container.insertAdjacentHTML('beforeend', fieldHtml);
                                    }
                                
                                    function removeCustomField(fieldId) {
                                        const field = document.getElementById(fieldId);
                                        if (field) {
                                            field.remove();
                                        }
                                    }
                                
                                    // ==================== QUILL EDITOR INITIALIZATION ====================
                                    function initializeQuill() {
                                        const editorElement = document.getElementById('editor');
                                        if (editorElement && !quill) {
                                            quill = new Quill('#editor', {
                                                theme: 'snow',
                                                modules: {
                                                    toolbar: [
                                                        [{ 'header': [1, 2, 3, false] }],
                                                        ['bold', 'italic', 'underline', 'strike'],
                                                        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                                                        ['link', 'image', 'video'],
                                                        ['clean'],
                                                        [{ 'align': [] }],
                                                        [{ 'color': [] }, { 'background': [] }],
                                                        ['code-block']
                                                    ]
                                                },
                                                placeholder: 'Write your blog content here...'
                                            });
                                            
                                            // Update hidden field on content change
                                            quill.on('text-change', function() {
                                                const hiddenField = document.getElementById('blogContentHidden');
                                                if (hiddenField) {
                                                    hiddenField.value = quill.root.innerHTML;
                                                }
                                            });
                                        }
                                    }
                                
                                    // ==================== UTILITY FUNCTIONS ====================
                                    function parseCommaList(value = "") {
                                        if (!value) return [];
                                        if (Array.isArray(value)) return value;
                                        if (typeof value === 'string' && value.trim().startsWith('[')) {
                                            try {
                                                return JSON.parse(value);
                                            } catch { }
                                        }
                                        return value.split(",").map(item => item.trim()).filter(Boolean);
                                    }
                                
                                    function toCommaSeparated(items = []) {
                                        if (!items) return "";
                                        if (Array.isArray(items)) return items.join(", ");
                                        if (typeof items === 'string') return items;
                                        return "";
                                    }
                                
                                    function formatDate(dateString) {
                                        if (!dateString) return "";
                                        try {
                                            const date = new Date(dateString);
                                            return date.toLocaleDateString('en-US', {
                                                year: 'numeric',
                                                month: 'short',
                                                day: 'numeric'
                                            });
                                        } catch {
                                            return dateString;
                                        }
                                    }
                                
                                    function formatDateTime(dateString) {
                                        if (!dateString) return "";
                                        try {
                                            const date = new Date(dateString);
                                            return date.toISOString().slice(0, 16);
                                        } catch {
                                            return dateString;
                                        }
                                    }
                                
                                    function truncateText(text, maxLength = 100) {
                                        if (!text) return "";
                                        if (text.length <= maxLength) return text;
                                        return text.substring(0, maxLength) + '...';
                                    }
                                
                                    function setFieldValue(fieldId, value) {
                                        const el = document.getElementById(fieldId);
                                        if (!el) {
                                            console.warn(`Field ${fieldId} not found`);
                                            return;
                                        }
                                
                                        if (el.type === 'checkbox') {
                                            el.checked = Boolean(value);
                                        } else if (el.tagName === 'SELECT') {
                                            el.value = value || "";
                                        } else {
                                            el.value = value || "";
                                        }
                                        
                                        el.dispatchEvent(new Event('change', { bubbles: true }));
                                        el.dispatchEvent(new Event('input', { bubbles: true }));
                                    }
                                
                                    // ==================== BLOG LIST FUNCTIONS ====================
                                    async function fetchBlogStats() {
                                        try {
                                            const response = await fetch("/admin/blogs/blog-stats")
                                            const data = await response.json();
                                            if (data.success) {
                                                blogStats = data.data;
                                                document.getElementById('totalViews').textContent = blogStats.totalViews || 0;
                                                document.getElementById('totalBlogs').textContent = blogStats.totalBlogs || 0;
                                            }
                                        } catch (error) {
                                            console.error('Error fetching stats:', error);
                                        }
                                    }
                                
                                    async function fetchCategories() {
                                        try {
                                            const response = await fetch("/admin/blogs/blog-categories")
                                            const data = await response.json();
                                            if (data.success) {
                                                categories = data.categories || [];
                                                updateCategoryLists();
                                                
                                                // Update category filter dropdown
                                                const categoryFilter = document.getElementById('categoryFilter');
                                                if (categoryFilter) {
                                                    categoryFilter.innerHTML = '<option value="">All Categories</option>' + 
                                                        categories.map(cat => `<option value="${cat}">${cat}</option>`).join('');
                                                }
                                            }
                                        } catch (error) {
                                            console.error('Error fetching categories:', error);
                                        }
                                    }
                                
                                    function updateCategoryLists() {
                                        const datalist = document.getElementById('categoriesList');
                                        const datalistEdit = document.getElementById('categoriesListEdit');
                                        const options = categories.map(cat => `<option value="${cat}">${cat}</option>`).join('');
                                        
                                        if (datalist) datalist.innerHTML = options;
                                        if (datalistEdit) datalistEdit.innerHTML = options;
                                    }
                                
                                    async function fetchBlogs(page = 1) {
                                        try {
                                            const status = document.getElementById('statusFilter')?.value || '';
                                            const category = document.getElementById('categoryFilter')?.value || '';
                                            const search = document.getElementById('searchBlogs')?.value || '';
                                
                                            let url = `/admin/blogs?page=${page}&limit=12`;
                                            if (status) url += `&status=${status}`;
                                            if (category) url += `&category=${category}`;
                                            if (search) url += `&search=${encodeURIComponent(search)}`;
                                
                                            console.log('Fetching blogs from:', url);
                                            const response = await fetch(url);
                                            
                                            if (!response.ok) {
                                                throw new Error(`HTTP error! status: ${response.status}`);
                                            }
                                            
                                            const data = await response.json();
                                
                                            if (data.success) {
                                                blogs = data.data || [];
                                                currentPage = data.pagination?.page || 1;
                                                totalPages = data.pagination?.pages || 1;
                                                renderBlogs();
                                                renderPagination();
                                            } else {
                                                throw new Error(data.message || 'Failed to fetch blogs');
                                            }
                                        } catch (error) {
                                            console.error('Error fetching blogs:', error);
                                            showToast('Error loading blogs: ' + error.message, 'error');
                                        }
                                    }
                                
                                    function debouncedSearch() {
                                        clearTimeout(searchTimeout);
                                        searchTimeout = setTimeout(() => {
                                            fetchBlogs(1);
                                        }, 500);
                                    }
                                
                                    function renderBlogs() {
                                        const blogList = document.getElementById('blog-list');
                                        if (!blogList) return;
                                
                                        if (!blogs.length) {
                                            blogList.innerHTML = `
                                                <div class="col-span-full text-center py-12">
                                                    <i class="icon-file-text text-4xl text-gray-300 mb-4"></i>
                                                    <h3 class="text-lg font-medium text-gray-500">No blogs found</h3>
                                                    <p class="text-gray-400 mt-2">Click "Add Blog" to create your first blog post.</p>
                                                </div>
                                            `;
                                            return;
                                        }
                                
                                        blogList.innerHTML = blogs.map(blog => `
                                            <div class="blog-card bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
                                                <div class="relative">
                                                    ${blog.featuredImage ?
                                                        `<img src="${blog.featuredImage}" alt="${blog.title}" class="w-full h-48 object-cover">` :
                                                        `<div class="w-full h-48 bg-gray-100 flex items-center justify-center">
                                                            <i class="icon-image text-4xl text-gray-300"></i>
                                                        </div>`
                                                    }
                                                    ${blog.featured ?
                                                        `<span class="absolute top-2 right-2 bg-yellow-500 text-white text-xs px-2 py-1 rounded">Featured</span>` :
                                                        ''
                                                    }
                                                    <span class="absolute top-2 left-2 status-badge status-${blog.status}">
                                                        ${blog.status?.charAt(0).toUpperCase() + blog.status?.slice(1) || 'Draft'}
                                                    </span>
                                                </div>
                                                
                                                <div class="p-4">
                                                    <div class="flex justify-between items-start mb-2">
                                                        <h3 class="font-semibold text-lg truncate" title="${blog.title || 'Untitled'}">${blog.title || 'Untitled'}</h3>
                                                    </div>
                                                    
                                                    <p class="text-gray-600 text-sm mb-3 line-clamp-2">${blog.excerpt || truncateText(blog.content || '', 80)}</p>
                                                    
                                                    <div class="flex items-center justify-between text-sm text-gray-500 mb-3">
                                                        <div class="flex items-center gap-2">
                                                            <i class="icon-user text-xs"></i>
                                                            <span>${blog.author?.name || 'Unknown'}</span>
                                                        </div>
                                                        <div class="flex items-center gap-2">
                                                            <i class="icon-eye text-xs"></i>
                                                            <span>${blog.views || 0}</span>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="flex items-center justify-between text-xs text-gray-500 mb-4">
                                                        <div>
                                                            <i class="icon-calendar text-xs"></i>
                                                            ${formatDate(blog.publishedAt || blog.createdAt)}
                                                        </div>
                                                        <div>
                                                            <i class="icon-clock text-xs"></i>
                                                            ${blog.readingTime || '--'} min read
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="flex gap-2">
                                                        <button onclick="showEditBlogModal('${blog._id}')" 
                                                                class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded text-sm transition">
                                                            <i class="icon-edit mr-1"></i> Edit
                                                        </button>
                                                        <button onclick="previewBlogById('${blog._id}')" 
                                                                class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 px-4 rounded text-sm transition">
                                                            <i class="icon-eye mr-1"></i> Preview
                                                        </button>
                                                        <button onclick="confirmDeleteBlog('${blog._id}')" 
                                                                class="flex-1 bg-red-100 hover:bg-red-200 text-red-800 py-2 px-4 rounded text-sm transition">
                                                            <i class="icon-trash-2 mr-1"></i> Delete
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        `).join('');
                                    }
                                
                                    function renderPagination() {
                                        const paginationContainer = document.getElementById('blogPagination');
                                        if (!paginationContainer || totalPages <= 1) {
                                            paginationContainer.innerHTML = '';
                                            return;
                                        }
                                
                                        let paginationHTML = `
                                            <nav class="flex items-center gap-2">
                                                <button onclick="changePage(${currentPage - 1})" 
                                                        ${currentPage === 1 ? 'disabled' : ''}
                                                        class="px-3 py-2 rounded border ${currentPage === 1 ? 'text-gray-400 cursor-not-allowed' : 'hover:bg-gray-100'}">
                                                    <i class="icon-chevron-left"></i>
                                                </button>
                                        `;
                                
                                        const maxVisible = 5;
                                        let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
                                        let endPage = Math.min(totalPages, startPage + maxVisible - 1);
                                
                                        if (endPage - startPage + 1 < maxVisible) {
                                            startPage = Math.max(1, endPage - maxVisible + 1);
                                        }
                                
                                        for (let i = startPage; i <= endPage; i++) {
                                            paginationHTML += `
                                                <button onclick="changePage(${i})" 
                                                        class="px-4 py-2 rounded border ${currentPage === i ? 'bg-blue-600 text-white' : 'hover:bg-gray-100'}">
                                                    ${i}
                                                </button>
                                            `;
                                        }
                                
                                        paginationHTML += `
                                                <button onclick="changePage(${currentPage + 1})" 
                                                        ${currentPage === totalPages ? 'disabled' : ''}
                                                        class="px-3 py-2 rounded border ${currentPage === totalPages ? 'text-gray-400 cursor-not-allowed' : 'hover:bg-gray-100'}">
                                                    <i class="icon-chevron-right"></i>
                                                </button>
                                            </nav>
                                        `;
                                
                                        paginationContainer.innerHTML = paginationHTML;
                                    }
                                
                                    function changePage(page) {
                                        if (page < 1 || page > totalPages) return;
                                        fetchBlogs(page);
                                    }
                                
                                    // ==================== BLOG FORM FUNCTIONS ====================
                                    function showAddBlogModal() {
                                        const form = document.getElementById('addBlogForm');
                                        if (form) form.reset();
                                
                                        // Clear previews
                                        document.getElementById('featuredImagePreview').innerHTML = '';
                                        document.getElementById('galleryPreview').innerHTML = '';
                                        
                                        // Clear custom fields
                                        document.getElementById('customFieldsContainer').innerHTML = '';
                                
                                        // Set default values
                                        const now = new Date();
                                        const formattedDate = now.toISOString().slice(0, 16);
                                        document.getElementById('blogPublishedAt').value = formattedDate;
                                
                                        // Clear Quill editor
                                        if (quill) {
                                            quill.setText('');
                                        }
                                
                                        document.getElementById('addBlogModal').style.display = 'block';
                                    }
                                
                                    async function showEditBlogModal(id) {
                                        try {
                                            console.log('Opening edit modal for blog ID:', id);
                                            
                                            const response = await fetch(`/admin/blogs/${id}`);
                                            if (!response.ok) {
                                                throw new Error(`HTTP error! status: ${response.status}`);
                                            }
                                            
                                            const data = await response.json();
                                            console.log('Blog data received:', data);
                                
                                            if (!data.success || !data.data) {
                                                throw new Error(data.message || 'Blog not found');
                                            }
                                
                                            const blog = data.data;
                                            console.log('Setting blog data:', blog);
                                
                                            // Set basic fields
                                            setFieldValue('editBlogId', blog._id || blog.id);
                                            setFieldValue('editBlogTitle', blog.title);
                                            setFieldValue('editBlogSlug', blog.slug);
                                            setFieldValue('editBlogExcerpt', blog.excerpt);
                                            setFieldValue('editBlogStatus', blog.status || 'draft');
                                            setFieldValue('editBlogCategory', blog.category || '');
                                            setFieldValue('editBlogTags', toCommaSeparated(blog.tags));
                                            setFieldValue('editBlogFeatured', blog.featured);
                                            setFieldValue('editBlogPublishedAt', blog.publishedAt ? formatDateTime(blog.publishedAt) : '');
                                            setFieldValue('editBlogMetaTitle', blog.metaTitle || blog.title);
                                            setFieldValue('editBlogMetaDescription', blog.metaDescription || blog.excerpt);
                                            setFieldValue('editBlogMetaKeywords', toCommaSeparated(blog.metaKeywords));
                                            setFieldValue('editBlogAuthorName', blog.author?.name || '');
                                            setFieldValue('editBlogAuthorBio', blog.author?.bio || '');
                                
                                            // Set content in editor
                                            const editor = document.getElementById('editBlogContent');
                                            if (editor) {
                                                editor.innerHTML = blog.content || '';
                                                // Update hidden field
                                                document.getElementById('editBlogContentHidden').value = blog.content || '';
                                            }
                                
                                            // Show featured image
                                            const featuredImgPreview = document.getElementById('editFeaturedImagePreview');
                                            if (featuredImgPreview) {
                                                if (blog.featuredImage) {
                                                    featuredImgPreview.innerHTML = `
                                                        <p class="text-sm text-gray-600 mb-2">Current Featured Image:</p>
                                                        <img src="${blog.featuredImage}" alt="Current featured image" class="max-h-40 object-contain rounded">
                                                    `;
                                                } else {
                                                    featuredImgPreview.innerHTML = '<p class="text-sm text-gray-500">No featured image</p>';
                                                }
                                            }
                                
                                            // Show gallery images
                                            const galleryContainer = document.getElementById('currentGalleryImages');
                                            if (galleryContainer) {
                                                if (blog.galleryImages && blog.galleryImages.length > 0) {
                                                    galleryContainer.innerHTML = `
                                                        <p class="text-sm font-medium mb-2">Current Gallery Images:</p>
                                                        <div class="grid grid-cols-4 gap-2">
                                                            ${blog.galleryImages.map((img, index) => `
                                                                <div class="relative">
                                                                    <img src="${img}" alt="Gallery image ${index + 1}" class="w-full h-20 object-cover rounded">
                                                                    <button type="button" onclick="removeGalleryImage('${blog._id}', '${img}')" 
                                                                            class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs">
                                                                        ×
                                                                    </button>
                                                                </div>
                                                            `).join('')}
                                                        </div>
                                                    `;
                                                } else {
                                                    galleryContainer.innerHTML = '<p class="text-gray-500 text-sm">No gallery images</p>';
                                                }
                                            }
                                
                                            // Show statistics
                                            document.getElementById('editBlogViews').textContent = blog.views || 0;
                                            document.getElementById('editBlogLikes').textContent = blog.likes || 0;
                                            document.getElementById('editBlogShares').textContent = blog.shares || 0;
                                            document.getElementById('editBlogReadingTime').textContent = blog.readingTime || '--';
                                
                                            // Show the modal
                                            document.getElementById('editBlogModal').style.display = 'block';
                                            console.log('Edit modal should be visible now');
                                
                                        } catch (error) {
                                            console.error('Error loading blog:', error);
                                            showToast('Error loading blog: ' + error.message, 'error');
                                        }
                                    }
                                
                                    function closeModal(modalId) {
                                        document.getElementById(modalId).style.display = 'none';
                                        
                                        // If closing add modal, reset custom fields
                                        if (modalId === 'addBlogModal') {
                                            document.getElementById('customFieldsContainer').innerHTML = '';
                                        }
                                    }
                                
                                    // ==================== IMAGE HANDLING ====================
                                    function setupImagePreviews() {
                                        // Featured image preview for add form
                                        const featuredInput = document.getElementById('blogFeaturedImage');
                                        if (featuredInput) {
                                            featuredInput.addEventListener('change', function (e) {
                                                const preview = document.getElementById('featuredImagePreview');
                                                preview.innerHTML = '';
                                
                                                if (this.files && this.files[0]) {
                                                    const reader = new FileReader();
                                                    reader.onload = function (e) {
                                                        preview.innerHTML = `
                                                            <img src="${e.target.result}" alt="Preview" class="max-h-40 object-contain rounded">
                                                        `;
                                                    }
                                                    reader.readAsDataURL(this.files[0]);
                                                }
                                            });
                                        }
                                
                                        // Gallery images preview for add form
                                        const galleryInput = document.getElementById('blogGalleryImages');
                                        if (galleryInput) {
                                            galleryInput.addEventListener('change', function (e) {
                                                const preview = document.getElementById('galleryPreview');
                                                preview.innerHTML = '';
                                
                                                for (let i = 0; i < Math.min(this.files.length, 10); i++) {
                                                    const reader = new FileReader();
                                                    reader.onload = function (e) {
                                                        preview.innerHTML += `
                                                            <div>
                                                                <img src="${e.target.result}" alt="Preview ${i + 1}" class="w-full h-20 object-cover rounded">
                                                            </div>
                                                        `;
                                                    }
                                                    reader.readAsDataURL(this.files[i]);
                                                }
                                            });
                                        }
                                
                                        // Featured image preview for edit form
                                        const editFeaturedInput = document.getElementById('editBlogFeaturedImage');
                                        if (editFeaturedInput) {
                                            editFeaturedInput.addEventListener('change', function (e) {
                                                const preview = document.getElementById('editFeaturedImagePreview');
                                                preview.innerHTML = '';
                                
                                                if (this.files && this.files[0]) {
                                                    const reader = new FileReader();
                                                    reader.onload = function (e) {
                                                        preview.innerHTML = `
                                                            <p class="text-sm text-gray-600 mb-2">New Featured Image:</p>
                                                            <img src="${e.target.result}" alt="Preview" class="max-h-40 object-contain rounded">
                                                        `;
                                                    }
                                                    reader.readAsDataURL(this.files[0]);
                                                }
                                            });
                                        }
                                
                                        // Gallery images preview for edit form
                                        const editGalleryInput = document.getElementById('editBlogGalleryImages');
                                        if (editGalleryInput) {
                                            editGalleryInput.addEventListener('change', function (e) {
                                                const preview = document.getElementById('editGalleryPreview');
                                                preview.innerHTML = '';
                                
                                                for (let i = 0; i < Math.min(this.files.length, 10); i++) {
                                                    const reader = new FileReader();
                                                    reader.onload = function (e) {
                                                        preview.innerHTML += `
                                                            <div>
                                                                <img src="${e.target.result}" alt="Preview ${i + 1}" class="w-full h-20 object-cover rounded">
                                                            </div>
                                                        `;
                                                    }
                                                    reader.readAsDataURL(this.files[i]);
                                                }
                                            });
                                        }
                                    }
                                
                                    async function removeGalleryImage(blogId, imageUrl) {
                                        if (!confirm('Are you sure you want to remove this image?')) return;
                                
                                        try {
                                            const response = await fetch(`/admin/blogs/${blogId}/gallery/${encodeURIComponent(imageUrl)}`, {
                                                method: 'DELETE'
                                            });
                                
                                            const data = await response.json();
                                            if (data.success) {
                                                showToast('Image removed successfully', 'success');
                                                showEditBlogModal(blogId); // Refresh the modal
                                            } else {
                                                throw new Error(data.message || 'Failed to remove image');
                                            }
                                        } catch (error) {
                                            console.error('Error removing image:', error);
                                            showToast('Error removing image: ' + error.message, 'error');
                                        }
                                    }
                                
                                    // ==================== TEXT EDITOR FUNCTIONS ====================
                                    function initializeEditors() {
                                        // Add placeholder to content editors
                                        const editors = ['blogContent', 'editBlogContent'];
                                        editors.forEach(editorId => {
                                            const editor = document.getElementById(editorId);
                                            if (editor) {
                                                editor.setAttribute('data-placeholder', 'Write your blog content here...');
                                                
                                                editor.addEventListener('focus', function () {
                                                    if (this.textContent === 'Write your blog content here...') {
                                                        this.textContent = '';
                                                    }
                                                });
                                                
                                                editor.addEventListener('blur', function () {
                                                    if (this.textContent === '') {
                                                        this.textContent = 'Write your blog content here...';
                                                    }
                                                });
                                            }
                                        });
                                    }
                                
                                    function formatText(command, value = null) {
                                        const editor = document.getElementById('blogContent');
                                        if (!editor) return;
                                
                                        document.execCommand(command, false, value);
                                        editor.focus();
                                
                                        // Update hidden field
                                        document.getElementById('blogContentHidden').value = editor.innerHTML;
                                    }
                                
                                    function formatEditText(command, value = null) {
                                        const editor = document.getElementById('editBlogContent');
                                        if (!editor) return;
                                
                                        document.execCommand(command, false, value);
                                        editor.focus();
                                
                                        // Update hidden field
                                        document.getElementById('editBlogContentHidden').value = editor.innerHTML;
                                    }
                                
                                    function insertImage() {
                                        const url = prompt('Enter image URL:');
                                        if (url) {
                                            formatText('insertImage', url);
                                        }
                                    }
                                
                                    function insertEditImage() {
                                        const url = prompt('Enter image URL:');
                                        if (url) {
                                            formatEditText('insertImage', url);
                                        }
                                    }
                                
                                    // ==================== FORM SUBMISSION ====================
                                    function setupBlogFormHandlers() {
                                        const addForm = document.getElementById('addBlogForm');
                                        const editForm = document.getElementById('editBlogForm');
                                
                                        // Auto-generate slug from title (add form)
                                        const titleInput = document.getElementById('blogTitle');
                                        const slugInput = document.getElementById('blogSlug');
                                        if (titleInput && slugInput) {
                                            titleInput.addEventListener('input', function () {
                                                if (!slugInput.value) {
                                                    slugInput.value = slugify(this.value);
                                                }
                                            });
                                        }
                                
                                        // Auto-generate slug from title (edit form)
                                        const editTitleInput = document.getElementById('editBlogTitle');
                                        const editSlugInput = document.getElementById('editBlogSlug');
                                        if (editTitleInput && editSlugInput) {
                                            editTitleInput.addEventListener('input', function () {
                                                if (!editSlugInput.value || editSlugInput.value === slugify(this.value)) {
                                                    editSlugInput.value = slugify(this.value);
                                                }
                                            });
                                        }
                                
                                        function slugify(text) {
                                            return text.toLowerCase()
                                                .replace(/[^\w\s]/g, '')
                                                .replace(/\s+/g, '-')
                                                .replace(/--+/g, '-')
                                                .trim();
                                        }
                                
                                        if (addForm) {
                                            addForm.addEventListener('submit', async function (e) {
                                                e.preventDefault();
                                
                                                // Update hidden content field from Quill
                                                if (quill) {
                                                    document.getElementById('blogContentHidden').value = quill.root.innerHTML;
                                                }
                                
                                                const formData = new FormData(this);
                                
                                                try {
                                                    const response = await fetch('/admin/blogs', {
                                                        method: 'POST',
                                                        body: formData
                                                    });
                                
                                                    const data = await response.json();
                                
                                                    if (data.success) {
                                                        showToast('Blog created successfully!', 'success');
                                                        closeModal('addBlogModal');
                                                        fetchBlogs();
                                                        fetchBlogStats();
                                                    } else {
                                                        throw new Error(data.message || 'Failed to create blog');
                                                    }
                                                } catch (error) {
                                                    console.error('Error creating blog:', error);
                                                    showToast('Error: ' + error.message, 'error');
                                                }
                                            });
                                        }
                                
                                        if (editForm) {
                                            editForm.addEventListener('submit', async function (e) {
                                                e.preventDefault();
                                
                                                // Update hidden content field
                                                const editor = document.getElementById('editBlogContent');
                                                const hiddenContent = document.getElementById('editBlogContentHidden');
                                                if (editor && hiddenContent) {
                                                    hiddenContent.value = editor.innerHTML;
                                                }
                                
                                                const formData = new FormData(this);
                                                const blogId = document.getElementById('editBlogId').value;
                                
                                                try {
                                                    const response = await fetch(`/admin/blogs/${blogId}`, {
                                                        method: 'PUT',
                                                        body: formData
                                                    });
                                
                                                    const data = await response.json();
                                
                                                    if (data.success) {
                                                        showToast('Blog updated successfully!', 'success');
                                                        closeModal('editBlogModal');
                                                        fetchBlogs();
                                                    } else {
                                                        throw new Error(data.message || 'Failed to update blog');
                                                    }
                                                } catch (error) {
                                                    console.error('Error updating blog:', error);
                                                    showToast('Error: ' + error.message, 'error');
                                                }
                                            });
                                        }
                                    }
                                
                                    // ==================== DELETE BLOG ====================
                                    async function confirmDeleteBlog(id) {
                                        if (!confirm('Are you sure you want to delete this blog? This action cannot be undone.')) {
                                            return;
                                        }
                                
                                        try {
                                            const response = await fetch(`/admin/blogs/${id}`, {
                                                method: 'DELETE'
                                            });
                                
                                            const data = await response.json();
                                
                                            if (data.success) {
                                                showToast('Blog deleted successfully!', 'success');
                                                fetchBlogs();
                                                fetchBlogStats();
                                            } else {
                                                throw new Error(data.message || 'Failed to delete blog');
                                            }
                                        } catch (error) {
                                            console.error('Error deleting blog:', error);
                                            showToast('Error: ' + error.message, 'error');
                                        }
                                    }
                                
                                    // ==================== PREVIEW FUNCTIONS ====================
                                    async function previewBlogById(id) {
                                        try {
                                            const response = await fetch(`/admin/blogs/${id}`);
                                            const data = await response.json();
                                
                                            if (data.success) {
                                                showPreview(data.data);
                                            }
                                        } catch (error) {
                                            console.error('Error previewing blog:', error);
                                            showToast('Error previewing blog: ' + error.message, 'error');
                                        }
                                    }
                                
                                    function previewBlog() {
                                        // Get data from edit form
                                        const title = document.getElementById('editBlogTitle')?.value || '';
                                        const content = document.getElementById('editBlogContent')?.innerHTML || '';
                                        const author = document.getElementById('editBlogAuthorName')?.value || '';
                                        const date = document.getElementById('editBlogPublishedAt')?.value || new Date().toISOString();
                                
                                        const previewData = {
                                            title,
                                            content,
                                            author: { name: author },
                                            publishedAt: date,
                                            excerpt: document.getElementById('editBlogExcerpt')?.value || '',
                                            featuredImage: document.getElementById('currentFeaturedImage')?.src || ''
                                        };
                                
                                        showPreview(previewData);
                                    }
                                
                                    function showPreview(blog) {
                                        const previewContent = document.getElementById('blogPreviewContent');
                                        if (!previewContent) return;
                                
                                        previewContent.innerHTML = `
                                            <article class="prose max-w-none">
                                                ${blog.featuredImage ?
                                                    `<img src="${blog.featuredImage}" alt="${blog.title}" class="w-full h-auto mb-6 rounded-lg">` :
                                                    ''
                                                }
                                                
                                                <h1 class="text-3xl font-bold mb-4">${blog.title}</h1>
                                                
                                                <div class="flex items-center gap-4 text-gray-600 mb-6">
                                                    ${blog.author?.name ?
                                                        `<span class="flex items-center gap-2">
                                                            <i class="icon-user"></i>
                                                            ${blog.author.name}
                                                        </span>` : ''
                                                    }
                                                    
                                                    <span class="flex items-center gap-2">
                                                        <i class="icon-calendar"></i>
                                                        ${new Date(blog.publishedAt).toLocaleDateString('en-US', {
                                                            year: 'numeric',
                                                            month: 'long',
                                                            day: 'numeric'
                                                        })}
                                                    </span>
                                                    
                                                    ${blog.readingTime ?
                                                        `<span class="flex items-center gap-2">
                                                            <i class="icon-clock"></i>
                                                            ${blog.readingTime} min read
                                                        </span>` : ''
                                                    }
                                                </div>
                                                
                                                ${blog.excerpt ?
                                                    `<div class="bg-gray-50 p-4 rounded-lg mb-6 italic">
                                                        ${blog.excerpt}
                                                    </div>` : ''
                                                }
                                                
                                                <div class="content mt-6">
                                                    ${blog.content}
                                                </div>
                                                
                                                ${blog.tags && blog.tags.length > 0 ?
                                                    `<div class="mt-8 pt-6 border-t">
                                                        <div class="flex flex-wrap gap-2">
                                                            ${blog.tags.map(tag =>
                                                                `<span class="px-3 py-1 bg-gray-100 rounded-full text-sm">${tag}</span>`
                                                            ).join('')}
                                                        </div>
                                                    </div>` : ''
                                                }
                                            </article>
                                        `;
                                
                                        document.getElementById('previewModal').style.display = 'block';
                                    }
                                
                                    // ==================== TOAST NOTIFICATION ====================
                                    function showToast(message, type = 'info') {
                                        // Remove existing toast
                                        const existingToast = document.querySelector('.toast');
                                        if (existingToast) existingToast.remove();
                                
                                        // Create toast
                                        const toast = document.createElement('div');
                                        toast.className = `toast toast-${type} fixed top-4 right-4 px-4 py-3 rounded-lg shadow-lg z-50 transform transition-all duration-300 translate-x-full`;
                                        
                                        // Get icon based on type
                                        let icon = 'info';
                                        if (type === 'success') icon = 'check-circle';
                                        if (type === 'error') icon = 'alert-circle';
                                        
                                        toast.innerHTML = `
                                            <div class="flex items-center gap-3">
                                                <i class="icon-${icon}"></i>
                                                <span class="text-sm font-medium">${message}</span>
                                            </div>
                                        `;
                                
                                        document.body.appendChild(toast);
                                
                                        // Animate in
                                        setTimeout(() => toast.classList.remove('translate-x-full'), 10);
                                
                                        // Auto remove after 3 seconds
                                        setTimeout(() => {
                                            toast.classList.add('translate-x-full');
                                            setTimeout(() => toast.remove(), 300);
                                        }, 3000);
                                    }
                                
                                    // ==================== BULK ACTIONS ====================
                                    async function updateBlogStatus(ids, status) {
                                        try {
                                            const response = await fetch('/admin/blogs/bulk-status', {
                                                method: 'PUT',
                                                headers: { 'Content-Type': 'application/json' },
                                                body: JSON.stringify({ ids, status })
                                            });
                                
                                            const data = await response.json();
                                            if (data.success) {
                                                showToast(`Updated ${ids.length} blog(s) successfully`, 'success');
                                                fetchBlogs();
                                            }
                                        } catch (error) {
                                            console.error('Error updating blog status:', error);
                                            showToast('Error updating blogs', 'error');
                                        }
                                    }
                                
                                    // Close modal when clicking outside
                                    window.onclick = function(event) {
                                        const modals = ['addBlogModal', 'editBlogModal', 'previewModal'];
                                        modals.forEach(modalId => {
                                            const modal = document.getElementById(modalId);
                                            if (event.target === modal) {
                                                closeModal(modalId);
                                            }
                                        });
                                    };
                                
                                    // Debug helper
                                    window.debugBlogs = function() {
                                        console.log('Blogs array:', blogs);
                                        console.log('Current page:', currentPage);
                                        console.log('Total pages:', totalPages);
                                        console.log('Categories:', categories);
                                        console.log('Stats:', blogStats);
                                    };
                                </script>
