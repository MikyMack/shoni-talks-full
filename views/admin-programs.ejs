                                    <h3>All Programs</h3>
                                    <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
                                        <li>
                                            <a href="/admin/admin-dashboard"><div class="text-tiny">Dashboard</div></a>
                                        </li>
                                        <li>
                                            <i class="icon-chevron-right"></i>
                                        </li>
                                        <li>
                                            <div class="text-tiny">Program Management</div>
                                        </li>
                                    </ul>
                                </div>
                                
                                <h3>Program Management</h3>

                                <div class="wg-box">

                                <div class="flex items-center justify-between gap10 flex-wrap">
                                    
                                    <!-- SEARCH -->
                                    <div class="wg-filter flex-grow">
                                    <form class="form-search" action="/admin/admin-programs" method="GET">
                                        <fieldset class="name">
                                        <input type="search" name="search" placeholder="Search programs..." value="<%= searchTerm %>">
                                        </fieldset>
                                        <div class="button-submit">
                                        <button type="submit"><i class="icon-search"></i></button>
                                        </div>
                                    </form>
                                    </div>

                                    <!-- ADD BUTTON -->
                                    <button class="tf-button style-1 w208" onclick="openProgramModal()">
                                    <i class="icon-plus"></i>Add Program
                                    </button>
                                </div>

                               <div class="st-data-grid">

                                <% if (programs.length > 0) { %>
                                    <% programs.forEach(program => { %>

                                    <div class="st-program-card" id="program-<%= program._id %>">

                                        <!-- Image Banner -->
                                        <div class="st-program-image">
                                        <img src="/uploads/<%= program.image %>" alt="">
                                        </div>

                                        <!-- Content -->
                                        <div class="st-program-content">
                                        
                                        <div class="st-program-header">
                                            <h3><%= program.title %></h3>
                                            <span class="st-category"><%= program.category %></span>
                                        </div>

                                        <p class="st-desc"><%= program.shortDescription %></p>

                                        <!-- Schedule -->
                                        <div class="st-schedule">
                                            <strong>Schedules:</strong>
                                            <ul>
                                            <% program.schedules.forEach(s => { %>
                                                <li>
                                                📅 <%= new Date(s.startDate).toDateString() %>  
                                                📍 <%= s.location %>
                                                </li>
                                            <% }) %>
                                            </ul>
                                        </div>

                                        </div>

                                        <!-- Footer -->
                                      <div class="st-card-footer"> 
                                        <button onclick="editProgram('<%= program._id %>')">✏️</button> 
                                        <button onclick="deleteProgram('<%= program._id %>')">🗑️</button>
                                     </div>

                                    </div>

                                    <% }) %>
                                <% } else { %>
                                    <p>No programs found</p>
                                <% } %>

                                </div>
                                <% if (totalPages > 1) { %>
<div class="pagination-wrapper">

  <!-- Prev -->
  <% if (currentPage > 1) { %>
    <a href="/admin/admin-programs?page=<%= currentPage - 1 %>&search=<%= searchTerm %>" class="page-btn">
      ← Prev
    </a>
  <% } %>

  <!-- Page Numbers -->
  <% for (let i = 1; i <= totalPages; i++) { %>
    <a 
      href="/admin/admin-programs?page=<%= i %>&search=<%= searchTerm %>" 
      class="page-number <%= currentPage === i ? 'active' : '' %>">
      <%= i %>
    </a>
  <% } %>

  <!-- Next -->
  <% if (currentPage < totalPages) { %>
    <a href="/admin/admin-programs?page=<%= currentPage + 1 %>&search=<%= searchTerm %>" class="page-btn">
      Next →
    </a>
  <% } %>

</div>
<% } %>
