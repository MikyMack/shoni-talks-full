<h3>User Purchases</h3>

<div class="wg-table table-all-category">

  <!-- HEADER -->
  <ul class="table-title flex gap20 mb-14">
    <li style="flex: 2;"><div class="body-title">User</div></li>
    <li style="flex: 2;"><div class="body-title">Item</div></li>
    <li style="flex: 1;"><div class="body-title">Type</div></li>
    <li style="flex: 1;"><div class="body-title">Amount</div></li>
    <li style="flex: 2;"><div class="body-title">Access</div></li>
    <li style="flex: 1;"><div class="body-title">Date</div></li>
  </ul>

  <!-- BODY -->
  <ul class="flex flex-column">

    <% if (purchases && purchases.length > 0) { %>

      <% purchases.forEach(p => { %>

        <li class="wg-product item-row gap20">

          <!-- USER -->
          <div style="flex: 2;">
            <div class="body-text text-main-dark">
              <%= p.user?.name || "N/A" %>
            </div>
            <div class="text-tiny text-muted">
              <%= p.user?.email %>
            </div>
          </div>

          <!-- ITEM -->
          <div style="flex: 2;" class="body-text mt-3">
            <% if (p.type === "course") { %>
              🎓 <%= p.course?.title %>
            <% } else { %>
              📦 <%= p.plan?.title %>
            <% } %>
          </div>

          <!-- TYPE -->
          <div style="flex: 1;" class="mt-3">
            <% if (p.type === "course") { %>
              <span class="badge bg-primary">Course</span>
            <% } else { %>
              <span class="badge bg-warning text-dark">Plan</span>
            <% } %>
          </div>

          <!-- AMOUNT -->
          <div style="flex: 1;" class="body-text mt-3">
            ₹<%= p.amount %>
          </div>

          <!-- ACCESS -->
          <div style="flex: 2;" class="mt-2">

            <% if (p.type === "course" && p.access) { %>

              <% if (!p.access.expiresAt) { %>
                <span class="text-success">Lifetime</span>
              <% } else { %>
                <span class="text-muted small">
                  till <%= new Date(p.access.expiresAt).toDateString() %>
                </span>
              <% } %>

            <% } %>

            <% if (p.type === "plan" && p.access && p.access.length > 0) { %>

              <details>
                <summary class="text-primary" style="cursor:pointer;">
                  View (<%= p.access.length %>)
                </summary>

                <ul class="small mt-2">
                  <% p.access.forEach(a => { %>
                    <li>
                      <%= a.course?.title %> -

                      <% if (!a.expiresAt) { %>
                        <span class="text-success">Lifetime</span>
                      <% } else { %>
                        till <%= new Date(a.expiresAt).toDateString() %>
                      <% } %>
                    </li>
                  <% }) %>
                </ul>
              </details>

            <% } %>

          </div>

          <!-- DATE -->
          <div style="flex: 1;" class="text-tiny mt-3">
            <%= new Date(p.createdAt).toLocaleDateString() %>
          </div>

        </li>

      <% }) %>

    <% } else { %>

      <div class="text-center py-4">
        <p>No purchases found</p>
      </div>

    <% } %>

  </ul>
</div>
