                <div class="row mt-3">
                  <% if (plans && plans.length > 0) { %>
                    <% plans.forEach(plan => { %>
                      <div class="col-md-6 mb-4">
                        <div class="plan-card <%= plan.isPopular ? 'highlight' : '' %>">
                          <div class="plan-header">
                            <h4><%= plan.title %></h4>
                            <span class="plan-badge">
                              <% if (plan.price === 0) { %>
                                Free
                              <% } else if (plan.offerPrice) { %>
                                <small class="text-decoration-line-through text-muted">₹<%= plan.price %></small> 
                                ₹<%= plan.offerPrice %>/<%= plan.duration.unit.replace(/s$/, '') %>
                              <% } else { %>
                                ₹<%= plan.price %>/<%= plan.duration.unit.replace(/s$/, '') %>
                              <% } %>
                            </span>
                          </div>

                          <ul class="plan-features">
                            <% if (plan.features && plan.features.length > 0) { %>
                              <% plan.features.forEach(feature => { %>
                                <li>✔ <%= feature %></li>
                              <% }) %>
                            <% } %>
                            
                            <% if (plan.sessions) { %>
                              <li>✔ <%= plan.sessions %> Live Sessions</li>
                            <% } %>
                          </ul>

                          <div class="plan-footer">
                            <% if (plan.isPopular) { %>
                              <span class="status upcoming">Best Value</span>
                            <% } else { %>
                              <span class="status active">Available</span>
                            <% } %>
                            <a href="/checkout/<%= plan._id %>" class="btn-link ms-auto">Select Plan</a>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="col-12">
                      <p class="text-muted">No subscription plans are available at this time.</p>
                    </div>
                  <% } %>
