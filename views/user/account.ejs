<h3>My Plans</h3>

<div class="row mt-3">
  <% if (purchasedPlans && purchasedPlans.length > 0) { %>

    <% purchasedPlans.forEach(plan => { %>
      <div class="col-md-6 mb-4">
        <div class="plan-card highlight">

          <!-- HEADER -->
          <div class="plan-header">
            <h4><%= plan.title %></h4>

            <% if (plan.isExpired) { %>
              <span class="status text-danger">Expired</span>
            <% } else { %>
              <span class="status active">Active</span>
            <% } %>
          </div>

          <!-- PLAN EXPIRY -->
          <p class="small mb-2">
            <% if (plan.expiresAt) { %>
              Valid till <%= new Date(plan.expiresAt).toDateString() %>
            <% } else { %>
              Lifetime Plan
            <% } %>
          </p>

          <!-- FEATURES -->
          <ul class="plan-features">
            <% if (plan.features && plan.features.length > 0) { %>
              <% plan.features.forEach(f => { %>
                <li>✔ <%= f %></li>
              <% }) %>
            <% } %>
          </ul>

          <!-- COURSES INSIDE PLAN -->
          <div class="mt-3">
            <h6>Included Courses</h6>

            <% if (plan.courses && plan.courses.length > 0) { %>
              <ul class="list-unstyled">

                <% plan.courses.forEach(course => { %>
                  <li class="d-flex justify-content-between align-items-center mb-2">

                    <span><%= course.title %></span>

                    <% if (course.isExpired) { %>
                      <span class="text-danger small">Expired</span>
                    <% } else if (course.expiresAt) { %>
                      <span class="text-muted small">
                        till <%= new Date(course.expiresAt).toDateString() %>
                      </span>
                    <% } else { %>
                      <span class="text-success small">Lifetime</span>
                    <% } %>

                  </li>
                <% }) %>

              </ul>
            <% } else { %>
              <p class="text-muted small">No courses in this plan</p>
            <% } %>
          </div>

        </div>
      </div>
    <% }) %>

  <% } else { %>
    <p class="text-muted">No plans purchased yet.</p>
  <% } %>
</div>

