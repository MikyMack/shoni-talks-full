    <script>
      function handleTabClick(e, id) {
        showTab(e, id);

        const offcanvasEl = document.getElementById("profileOffcanvas");
        const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasEl);
        offcanvas.hide();
      }
    </script>
    <script>
      function showTab(e, id) {
        // Hide all tabs
        document.querySelectorAll(".profile-tab").forEach((tab) => {
          tab.classList.add("d-none");
        });

        document.getElementById(id).classList.remove("d-none");

        // Remove active from sidebar
        document.querySelectorAll(".profile-sidebar li").forEach((li) => {
          li.classList.remove("active");
        });

        // Remove active from offcanvas
        document
          .querySelectorAll(".profile-offcanvas-menu li")
          .forEach((li) => {
            li.classList.remove("active");
          });

        // Add active to clicked item
        e.target.classList.add("active");

        // Sync highlight in BOTH menus
        document
          .querySelectorAll(`.profile-sidebar li, .profile-offcanvas-menu li`)
          .forEach((li) => {
            if (li.textContent.trim() === e.target.textContent.trim()) {
              li.classList.add("active");
            }
          });
      }
      function viewCourse(courseName) {
        // 1. Update Title and Hide/Show elements
        document.getElementById("courseTabTitle").innerText = courseName;
        document.getElementById("courseGridView").classList.add("d-none");
        document.getElementById("courseActions").classList.add("d-none");

        document.getElementById("courseVideoView").classList.remove("d-none");
        document.getElementById("backToCourses").classList.remove("d-none");
      }

      function exitCourse() {
        // 1. Reset Title
        document.getElementById("courseTabTitle").innerText = "My Courses";

        // 2. Toggle Visibility
        document.getElementById("courseGridView").classList.remove("d-none");
        document.getElementById("courseActions").classList.remove("d-none");

        document.getElementById("courseVideoView").classList.add("d-none");
        document.getElementById("backToCourses").classList.add("d-none");
      }
    </script>
