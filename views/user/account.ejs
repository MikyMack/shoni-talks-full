    <!-- edit profile -->
<script>
document.getElementById("profileForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const form = e.target;

  const data = {
    name: form.name.value,
    mobile: form.mobile.value,
  };

  const res = await fetch("/account/update", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify(data),
  });

  const result = await res.json();

  if (res.ok) {
    showToast("Profile updated successfully",'success');
    location.reload();
  } else {
    showToast(result.message || "Update failed",'error');
  }
});
</script>
    <script>
      function handleTabClick(e, id) {
        showTab(e, id);

        const offcanvasEl = document.getElementById("profileOffcanvas");
        const offcanvas = bootstrap.Offcanvas.getInstance(offcanvasEl);
        offcanvas.hide();
      }
    </script>
    <script>
      function showTab(e, id) {
        // Hide all tabs
        document.querySelectorAll(".profile-tab").forEach((tab) => {
          tab.classList.add("d-none");
        });

        document.getElementById(id).classList.remove("d-none");

        // Remove active from sidebar
        document.querySelectorAll(".profile-sidebar li").forEach((li) => {
          li.classList.remove("active");
        });

        // Remove active from offcanvas
        document
          .querySelectorAll(".profile-offcanvas-menu li")
          .forEach((li) => {
            li.classList.remove("active");
          });

        // Add active to clicked item
        e.target.classList.add("active");

        // Sync highlight in BOTH menus
        document
          .querySelectorAll(`.profile-sidebar li, .profile-offcanvas-menu li`)
          .forEach((li) => {
            if (li.textContent.trim() === e.target.textContent.trim()) {
              li.classList.add("active");
            }
          });
      }
     

      async function viewCourse(courseId, courseTitle) {
  try {
    // UI toggle
    document.getElementById("courseTabTitle").innerText = courseTitle;
    document.getElementById("courseGridView").classList.add("d-none");
    document.getElementById("courseActions").classList.add("d-none");
    document.getElementById("courseVideoView").classList.remove("d-none");
    document.getElementById("backToCourses").classList.remove("d-none");

    // 🔥 FETCH VIDEOS FROM BACKEND
    const res = await fetch(`/course/${courseId}/videos`);
    const data = await res.json();

    if (!res.ok) {
      alert(data.message || "Cannot load videos");
      return;
    }

    renderVideos(data.videos);

  } catch (err) {
    console.error(err);
    alert("Something went wrong");
  }
}


      function exitCourse() {
        // 1. Reset Title
        document.getElementById("courseTabTitle").innerText = "My Courses";

        // 2. Toggle Visibility
        document.getElementById("courseGridView").classList.remove("d-none");
        document.getElementById("courseActions").classList.remove("d-none");

        document.getElementById("courseVideoView").classList.add("d-none");
        document.getElementById("backToCourses").classList.add("d-none");
      }
    function renderVideos(videos) {
        console.log("VIDEOS:", videos);
  const container = document.getElementById("courseSpecificVideos");
  container.innerHTML = "";

  videos.forEach(video => {

    const isLocked = !video.isUnlocked;

container.innerHTML += `
  <div class="col-md-6 mb-3">
    <div class="video-card ${isLocked ? "locked" : ""}">

      ${
        isLocked
          ? `<div class="video-overlay">🔒 Locked</div>`
          : `
          <div class="video-wrapper">
   <iframe 
                src="${formatYoutube(video.url)}"
                allowfullscreen>
              </iframe>

  <!-- TOP FULL BAR -->
  <div class="yt-block-top-full"></div>

  <!-- BOTTOM CENTER -->
  <div class="yt-block-bottom-center"></div>

  <!-- BOTTOM RIGHT -->
  <div class="yt-block-bottom-right"></div>
</div>
          `
      }

      <div class="video-info">
        <h5>${video.title}</h5>
      </div>

    </div>
  </div>
`;
  
  });
}

function formatYoutube(url) {
  let videoId = "";

  if (url.includes("youtu.be")) {
    videoId = url.split("youtu.be/")[1]?.split("?")[0];
  } else if (url.includes("v=")) {
    videoId = url.split("v=")[1]?.split("&")[0];
  }

  return `https://www.youtube-nocookie.com/embed/${videoId}?modestbranding=1&rel=0&controls=1&disablekb=1&fs=0`;
}
    
    </script>

