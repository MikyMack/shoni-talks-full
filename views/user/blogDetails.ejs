    <link href="/css/custom.css" rel="stylesheet" media="screen" />
      <!-- toastify CSS -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  </head>
  <body>

    <!-- Floating Icon Start-->
    <%- include('../partials/floatingIcons.ejs') %>
    <!-- Floating Icon End -->


    <!-- Header Start -->
	  <%- include('../partials/header.ejs') %>
    <!-- Header End -->

    <!-- Page Header Start -->
<div class="page-header bg-section dark-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-12">
        <div class="page-header-box">

          <!-- TITLE -->
          <h1 class="text-anime-style-3">
            <%= blog.title %>
          </h1>

          <!-- META -->
          <div class="post-single-meta">
            <ol class="breadcrumb">

              <!-- AUTHOR -->
              <li>
                <i class="fa-regular fa-user"></i> 
                <%= blog.author?.name || "Shony Talks" %>
              </li>

              <% if (blog.publishedAt || blog.createdAt) { %>
                <li>
                  <i class="fa-regular fa-clock"></i> 
                  <%= blog.formattedDate %>
                </li>
              <% } %>
            </ol>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
    <!-- Page Header End -->

    <!-- Page Single Post Start -->
    <div class="page-single-post">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">

        <!-- ================= IMAGE ================= -->
        <div class="post-image">
          <figure class="image-anime reveal">
            <img 
              src="<%= blog.featuredImage ? blog.featuredImage : '/images/default.jpg' %>" 
              alt="<%= blog.title %>" 
            />
          </figure>
        </div>

        <!-- ================= CONTENT ================= -->
        <div class="post-content">

          <!-- Title -->
          <h1 class="mb-3"><%= blog.title %></h1>

          <!-- Date -->
          <p class="text-muted mb-4">
            <%= blog.formattedDate %>
          </p>

          <!-- Main Content -->
          <div class="post-entry">
            <%- blog.content %>  <!-- IMPORTANT: unescaped HTML -->
          </div>

          <!-- ================= TAGS + SOCIAL ================= -->
          <div class="post-tag-links mt-5">
            <div class="row align-items-center">

              <!-- TAGS -->
              <div class="col-lg-8">
                <div class="post-tags">

<span class="tag-links">
  Tags:
  <% if (blog.tags && blog.tags.length) { %>
    <% blog.tags.forEach(tag => { %>
      <a href="/blogs?tag=<%= tag %>"><%= tag %></a>
    <% }) %>
  <% } else { %>
    <span>No tags</span>
  <% } %>
</span>
                </div>
              </div>

              <!-- SOCIAL -->
              <!-- <div class="col-lg-4">
                <div class="post-social-sharing">
                  <ul>
                    <li>
                      <a href="#">
                        <i class="fa-brands fa-facebook-f"></i>
                      </a>
                    </li>
                    <li>
                      <a href="#">
                        <i class="fa-brands fa-linkedin-in"></i>
                      </a>
                    </li>
                    <li>
                      <a href="#">
                        <i class="fa-brands fa-instagram"></i>
                      </a>
                    </li>
                    <li>
                      <a href="#">
                        <i class="fa-brands fa-x-twitter"></i>
                      </a>
                    </li>
                  </ul>
                </div>
              </div> -->

            </div>
          </div>

        </div>

      </div>
    </div>

    <!-- ================= RELATED BLOGS ================= -->
    <% if (relatedBlogs && relatedBlogs.length) { %>
      <div class="row mt-5">
        <div class="col-lg-12">
          <h3 class="mb-4">Related Posts</h3>
        </div>

        <% relatedBlogs.forEach(item => { %>
          <div class="col-lg-4 col-md-6">
            <div class="post-item">

              <div class="post-featured-image">
                <a href="/blog/<%= item.slug %>">
                  <figure class="image-anime">
                    <img 
                      src="<%= item.featuredImage || '/images/default.jpg' %>"
                      alt="<%= item.title %>" 
                    />
                  </figure>
                </a>
              </div>

              <div class="post-item-body">
                <div class="post-item-content">
                  <h3>
                    <a href="/blog/<%= item.slug %>">
                      <%= item.title %>
                    </a>
                  </h3>
                </div>

                <div class="post-item-btn">
                  <a href="/blog/<%= item.slug %>" class="readmore-btn">
                    read more
                  </a>
                </div>
              </div>

            </div>
          </div>
        <% }) %>

      </div>
    <% } %>

  </div>
</div>
    <!-- Page Single Post End -->

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
    <!-- Main Footer Section End -->

     <!-- Login modal start -->
    <div class="modal fade" id="authModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content auth-modal">
          <!-- Close -->
          <button
            type="button"
            class="btn-close custom-close"
            data-bs-dismiss="modal"
          ></button>

          <div class="row g-0">
            <!-- LEFT IMAGE -->
            <div class="col-lg-6 d-none d-lg-block">
              <div class="auth-image">
                <div class="auth-overlay">
                  <h3 class="text-light mb-3">Welcome to Shony Talks</h3>
                  <p>Start your journey of transformation today.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-6 col-12">
              <div class="auth-body">
                <h4 class="mb-3">Login </h4>

                <!-- STEP 1 -->
                <form id="loginForm">
                  <div class="mb-3">
                    <input type="text" id="name" class="form-control" placeholder="Full Name" required />
                  </div>

                  <div class="mb-3">
                    <input type="email" id="email" class="form-control" placeholder="Email Address" required />
                  </div>

                  <button id="otpBtn" type="button" onclick="sendOtp()" class="btn-default btn-highlighted w-100">
                  Get OTP
                </button>
                </form>

                <!-- STEP 2 OTP -->
                <div id="otpSection" style="display: none">
                  <p class="mb-2">Enter OTP sent to your email</p>

                  <div class="otp-box mb-3">
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                  </div>

                <button id="verifyBtn" type="button" onclick="verifyOtp()" class="btn-default btn-highlighted w-100 mb-3">
                  Verify OTP
                </button>
                  <div class="text-center">
                    <a href="#" onclick="resendOtp()">Resend OTP</a>
                  </div>
                </div>

                <!-- DIVIDER -->
                <div class="auth-divider">
                  <span>OR</span>
                </div>

                <!-- GOOGLE LOGIN -->
                <a href="/auth/google" class="google-btn w-100 d-flex justify-content-center align-items-center text-decoration-none">
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                  alt=""
                />
                Continue with Google
              </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Login modal end -->

    <!-- Mobile Bottom Navbar Start -->
    <%- include('../partials/mobileNav.ejs') %>
    <!-- Mobile Bottom Navbar End -->

    <!-- Jquery Library File -->
    <script src="/js/jquery-3.7.1.min.js"></script>
    <!-- Circle Progress Js File -->
    <script src="/js/circle-progress.min.js"></script>
    <!-- Bootstrap js file -->
    <script src="/js/bootstrap.min.js"></script>
    <!-- Validator js file -->
    <script src="/js/validator.min.js"></script>
    <!-- SlickNav js file -->
    <script src="/js/jquery.slicknav.js"></script>
    <!-- Swiper js file -->
    <script src="/js/swiper-bundle.min.js"></script>
    <!-- Counter js file -->
    <script src="/js/jquery.waypoints.min.js"></script>
    <script src="/js/jquery.counterup.min.js"></script>
    <!-- Magnific js file -->
    <script src="/js/jquery.magnific-popup.min.js"></script>
    <!-- Parallax js -->
    <script src="/js/parallaxie.js"></script>
    <!-- MagicCursor js file -->
    <script src="/js/gsap.min.js"></script>
    <script src="/js/magiccursor.js"></script>
    <!-- Text Effect js file -->
    <script src="/js/SplitText.js"></script>
    <script src="/js/ScrollTrigger.min.js"></script>
    <!-- YTPlayer js File -->
    <script src="/js/jquery.mb.YTPlayer.min.js"></script>
    <!-- Wow js file -->
    <script src="/js/wow.min.js"></script>
    <!-- Main Custom js file -->
    <script src="/js/function.js"></script>
    <script src="js/auth.js"></script>
    <!-- toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  </body>

