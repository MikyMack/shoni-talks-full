  <body>

    <!-- Floating Icon Start-->
    <%- include('../partials/floatingIcons.ejs') %>
    <!-- Floating Icon End -->
    <!-- Header Start -->
	  <%- include('../partials/header.ejs') %>
    <!-- Header End -->

    <!-- Page Header Start -->
    <div class="page-header bg-section dark-section">
      <div class="container">
        <div class="row">
          <div class="col-lg-12">
            <!-- Page Header Box Start -->
            <div class="page-header-box">
              <h1 class="text-anime-style-3" data-cursor="-opaque">
                Courses
              </h1>

        <p class="text-light opacity-75 mb-0">
          Explore structured courses designed to improve your skills and knowledge.
        </p>
              
            </div>
            <!-- Page Header Box End -->
          </div>
        </div>
      </div>
    </div>
    <!-- Page Header End -->

    
<div class="course-single-section bg-section py-5">
  <div class="container">
    <div class="row g-4">

      <!-- ================= LEFT CONTENT ================= -->
      <div class="col-lg-8">

        <div class="course-details-content">

          <!-- TITLE -->
          <div class="mb-4">
            <h1 class="fw-bold display-6">
              <%= course.title %>
            </h1>

            <% if (course.shortDescription) { %>
              <p class="text-muted fs-5 mt-2">
                <%= course.shortDescription %>
              </p>
            <% } %>
          </div>

          <!-- IMAGE -->
          <% if (course.image) { %>
            <div class="mb-4">
              <img
                src="/uploads/<%= course.image %>"
                class="img-fluid rounded-4 shadow-sm"
                style="width: 100%; object-fit: cover;"
              />
            </div>
          <% } %>

          <!-- DESCRIPTION -->
          <div class="mb-5">
            <h4 class="mb-3">About This Course</h4>

            <p class="text-muted">
              <%= course.description %>
            </p>
          </div>

          <!-- LEARNINGS -->
          <% if (course.learnings && course.learnings.length) { %>
            <div class="mb-5">
              <h4 class="mb-3">What You’ll Learn</h4>

              <ul class="list-unstyled">
                <% course.learnings.forEach(item => { %>
                  <li class="mb-2">
                    <i class="fa-solid fa-check text-success me-2"></i>
                    <%= item %>
                  </li>
                <% }) %>
              </ul>
            </div>
          <% } %>

        </div>
      </div>

      <!-- ================= RIGHT SIDEBAR ================= -->
      <div class="col-lg-4">

        <div class="course-sidebar" style="position: sticky; top: 100px;">

          <div class="course-preview-card bg-white rounded-4 shadow-sm p-3">

            <!-- PREVIEW VIDEO -->
<% if (course.previewVideo) { %>
  <div class="video-wrapper">

    <iframe
      src="<%= course.previewVideo %>"
      allow="autoplay; encrypted-media"
      >
    </iframe>

    <!-- TOP BLOCK (title + YouTube link area) -->
    <div class="video-block-top"></div>

    <!-- BOTTOM BLOCK (logo + share + watch on youtube) -->
    <div class="video-block-bottom"></div>

  </div>
<% } %>

            <!-- COURSE INFO BOX -->
            <% if (
              course.videoHours ||
              course.resourcesCount ||
              course.hasCertificate ||
              course.directAccessType
            ) { %>

              <div class="border rounded-3 p-3 mb-3">

                <h6 class="fw-semibold mb-3">Course Includes</h6>

                <ul class="list-unstyled small mb-0">

                  <% if (course.videoHours) { %>
                    <li class="mb-2">
                      🎥 <%= course.videoHours %> hours content
                    </li>
                  <% } %>

                  <% if (course.resourcesCount) { %>
                    <li class="mb-2">
                      📄 <%= course.resourcesCount %> resources
                    </li>
                  <% } %>

                  <% if (course.directAccessType) { %>
                    <li class="mb-2">
                      🔓 <%= course.directAccessType === "lifetime"
                        ? "Lifetime access"
                        : "Limited access" %>
                    </li>
                  <% } %>

                  <% if (course.hasCertificate) { %>
                    <li>
                      🏆 Certificate included
                    </li>
                  <% } %>

                </ul>

              </div>

            <% } %>

            <!-- PRICE -->
            <div class="mb-3">
              <h2 class="fw-bold mb-0">
                ₹<%= course.offerPrice || course.price %>

                <% if (course.offerPrice && course.offerPrice < course.price) { %>
                  <span class="text-muted text-decoration-line-through fs-6 ms-2">
                    ₹<%= course.price %>
                  </span>
                <% } %>
              </h2>
            </div>

            <!-- BUY BUTTON -->
            <a href="javascript:void(0)"
              class="buy-btn d-grid"
              data-type="course"
              data-id="<%= course._id %>"
              data-auth="<%= user ? 1 : 0 %>">

              <button class="btn btn-default btn-lg rounded-3">
                Buy Now
              </button>
            </a>

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
    <!-- Main Footer Section End -->

     <!-- Login modal start -->
    <div class="modal fade" id="authModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content auth-modal">
          <!-- Close -->
          <button
            type="button"
            class="btn-close custom-close"
            data-bs-dismiss="modal"
          ></button>

          <div class="row g-0">
            <!-- LEFT IMAGE -->
            <div class="col-lg-6 d-none d-lg-block">
              <div class="auth-image">
                <div class="auth-overlay">
                  <h3 class="text-light mb-3">Welcome to Shony Talks</h3>
                  <p>Start your journey of transformation today.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-6 col-12">
              <div class="auth-body">
                <h4 class="mb-3">Login </h4>

                <!-- STEP 1 -->
                <form id="loginForm">
                  <div class="mb-3">
                    <input type="text" id="name" class="form-control" placeholder="Full Name" required />
                  </div>

                  <div class="mb-3">
                    <input type="email" id="email" class="form-control" placeholder="Email Address" required />
                  </div>

                  <button id="otpBtn" type="button" onclick="sendOtp()" class="btn-default btn-highlighted w-100">
                  Get OTP
                </button>
                </form>

                <!-- STEP 2 OTP -->
                <div id="otpSection" style="display: none">
                  <p class="mb-2">Enter OTP sent to your email</p>

                  <div class="otp-box mb-3">
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                  </div>

                <button id="verifyBtn" type="button" onclick="verifyOtp()" class="btn-default btn-highlighted w-100 mb-3">
                  Verify OTP
                </button>
                  <div class="text-center">
                    <a href="#" onclick="resendOtp()">Resend OTP</a>
                  </div>
                </div>

                <!-- DIVIDER -->
                <div class="auth-divider">
                  <span>OR</span>
                </div>

                <!-- GOOGLE LOGIN -->
                <button class="google-btn w-100">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                    alt=""
                  />
                  Continue with Google
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Login modal end -->

    <!-- Mobile Bottom Navbar Start -->
    <%- include('../partials/mobileNav.ejs') %>
    <!-- Mobile Bottom Navbar End -->

    <!-- Jquery Library File -->
     <script>
  document.addEventListener("DOMContentLoaded", function () {
    const buyButtons = document.querySelectorAll(".buy-btn");

    buyButtons.forEach(btn => {
      btn.addEventListener("click", function () {
        const isAuth = this.dataset.auth === "1";

        if (!isAuth) {
          // show auth modal
          const modal = new bootstrap.Modal(document.getElementById('authModal'));
          modal.show();

          // show toast message
          showToast("Please login to continue",'error');

          return;
        }

        // if logged in → proceed to checkout
        const type = this.dataset.type;
        const id = this.dataset.id;

        window.location.href = `/checkout/${type}/${id}`;
      });
    });

  });
</script>
    <script>
      function showTab(e, id) {
        document.querySelectorAll(".profile-tab").forEach((tab) => {
          tab.classList.add("d-none");
        });

        document.getElementById(id).classList.remove("d-none");

        document.querySelectorAll(".profile-sidebar li").forEach((li) => {
          li.classList.remove("active");
        });

        e.target.classList.add("active");
      }
    </script>
