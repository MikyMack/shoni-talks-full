<div class="course-single-section bg-section py-5" style="margin-bottom: 60px;">
  <div class="container">
    <div class="row">

      <!-- LEFT -->
      <div class="col-lg-8">
        <div class="course-details-content">

          <!-- HEADER -->
          <div class="course-header mb-4">
            <h1 class="display-5 fw-bold"><%= course.title %></h1>

            <% if (course.shortDescription) { %>
              <p class="lead"><%= course.shortDescription %></p>
            <% } %>
          </div>

          <!-- IMAGE -->
          <div class="course-main-thumb mb-4">
            <img 
              src="/uploads/<%= course.image || 'default.jpg' %>" 
              class="img-fluid rounded-4 shadow-sm"
            >
          </div>

          <!-- DESCRIPTION -->
          <div class="course-description mb-5">
            <h3 class="mb-3">About This Course</h3>
            <p><%= course.description %></p>

            <% if (course.learnings && course.learnings.length > 0) { %>
              <h4 class="mt-4 mb-3">What You Will Learn</h4>

              <ul class="list-check">
                <% course.learnings.forEach(item => { %>
                  <li>
                    <i class="fa-solid fa-check text-primary me-2"></i>
                    <%= item %>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>

        </div>
      </div>

      <!-- RIGHT -->
      <div class="col-lg-4">
        <div class="course-sidebar sticky-top" style="top: 100px; z-index: 10;">
          <div class="course-preview-card bg-white p-3 rounded-4 shadow">

            <!-- VIDEO -->
            <% if (course.previewVideo) { %>
              <div class="video-preview-wrapper mb-3">
                <div class="ratio ratio-16x9 rounded overflow-hidden">
                  <iframe 
                    src="<%= course.previewVideo %>" 
                    allowfullscreen>
                  </iframe>
                </div>
              </div>
            <% } %>

            <!-- PRICE -->
            <div class="price-box mb-3">
              <h2 class="fw-bold mb-0">
                ₹<%= course.offerPrice || course.price %>

                <% if (course.offerPrice && course.offerPrice < course.price) { %>
                  <span class="fs-6 text-muted text-decoration-line-through">
                    ₹<%= course.price %>
                  </span>
                <% } %>
              </h2>
            </div>

            <!-- BUTTON -->
            <a href="#" class="d-grid gap-2">
              <button class="btn-default">Buy Now</button>
            </a>

            <!-- INCLUDES -->
            <div class="course-includes mt-4">
              <h6 class="fw-bold">This course includes:</h6>

              <ul class="list-unstyled small mt-2">

                <% if (course.videoHours) { %>
                  <li class="mb-2">
                    <i class="fa-regular fa-circle-play me-2"></i>
                    <%= course.videoHours %> hours video
                  </li>
                <% } %>

                <% if (course.resourcesCount) { %>
                  <li class="mb-2">
                    <i class="fa-regular fa-file me-2"></i>
                    <%= course.resourcesCount %> resources
                  </li>
                <% } %>

                <% if (course.lifetimeAccess) { %>
                  <li class="mb-2">
                    <i class="fa-solid fa-infinity me-2"></i>
                    Lifetime access
                  </li>
                <% } %>

                <% if (course.hasCertificate) { %>
                  <li>
                    <i class="fa-solid fa-trophy me-2"></i>
                    Certificate included
                  </li>
                <% } %>

              </ul>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</div>
    

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
    <!-- Main Footer Section End -->

     <!-- Login modal start -->
    <div class="modal fade" id="authModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content auth-modal">
          <!-- Close -->
          <button
            type="button"
            class="btn-close custom-close"
            data-bs-dismiss="modal"
          ></button>

          <div class="row g-0">
            <!-- LEFT IMAGE -->
            <div class="col-lg-6 d-none d-lg-block">
              <div class="auth-image">
                <div class="auth-overlay">
                  <h3 class="text-light mb-3">Welcome to Shony Talks</h3>
                  <p>Start your journey of transformation today.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-6 col-12">
              <div class="auth-body">
                <h4 class="mb-3">Login </h4>

                <!-- STEP 1 -->
                <form id="loginForm">
                  <div class="mb-3">
                    <input type="text" id="name" class="form-control" placeholder="Full Name" required />
                  </div>

                  <div class="mb-3">
                    <input type="email" id="email" class="form-control" placeholder="Email Address" required />
                  </div>

                  <button id="otpBtn" type="button" onclick="sendOtp()" class="btn-default btn-highlighted w-100">
                  Get OTP
                </button>
                </form>

                <!-- STEP 2 OTP -->
                <div id="otpSection" style="display: none">
                  <p class="mb-2">Enter OTP sent to your email</p>

                  <div class="otp-box mb-3">
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                  </div>

                <button id="verifyBtn" type="button" onclick="verifyOtp()" class="btn-default btn-highlighted w-100 mb-3">
                  Verify OTP
                </button>
                  <div class="text-center">
                    <a href="#" onclick="resendOtp()">Resend OTP</a>
                  </div>
                </div>

                <!-- DIVIDER -->
                <div class="auth-divider">
                  <span>OR</span>
                </div>

                <!-- GOOGLE LOGIN -->
                <button class="google-btn w-100">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                    alt=""
                  />
                  Continue with Google
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
