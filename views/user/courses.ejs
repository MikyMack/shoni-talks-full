    <!-- Page Title -->
    <title>Shony Talks - Courses</title>
    <!-- Favicon Icon -->
    <link rel="shortcut icon" type="image/x-icon" href="images/favicon.png" />
    <!-- Google Fonts Css-->
    <link rel="preconnect" href="https://fonts.googleapis.com/" />
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;family=Epilogue:ital,wght@0,100..900;1,100..900&amp;display=swap"
      rel="stylesheet"
    />
    <!-- Bootstrap Css -->
    <link href="css/bootstrap.min.css" rel="stylesheet" media="screen" />
    <!-- SlickNav Css -->
    <link href="css/slicknav.min.css" rel="stylesheet" />
    <!-- Swiper Css -->
    <link rel="stylesheet" href="css/swiper-bundle.min.css" />
    <!-- Font Awesome Icon Css-->
    <link href="css/all.min.css" rel="stylesheet" media="screen" />
    <!-- Animated Css -->
    <link href="css/animate.css" rel="stylesheet" />
    <!-- Magnific Popup Core Css File -->
    <link rel="stylesheet" href="css/magnific-popup.css" />
    <!-- Mouse Cursor Css File -->
    <link rel="stylesheet" href="css/mousecursor.css" />
    <!-- Main Custom Css -->
    <link href="css/custom.css" rel="stylesheet" media="screen" />

      <!-- toastify CSS -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  </head>
  <body>

    <!-- Floating Icon Start-->
    <%- include('../partials/floatingIcons.ejs') %>
    <!-- Floating Icon End -->
    <!-- Header Start -->
	  <%- include('../partials/header.ejs') %>
    <!-- Header End -->

    <!-- Page Header Start -->
    <div class="page-header bg-section dark-section">
      <div class="container">
        <div class="row">
          <div class="col-lg-12">
            <!-- Page Header Box Start -->
            <div class="page-header-box">
              <h1 class="text-anime-style-3" data-cursor="-opaque">
                Courses
              </h1>
              
            </div>
            <!-- Page Header Box End -->
          </div>
        </div>
      </div>
    </div>
    <!-- Page Header End -->

    <!-- Courses Section Start -->
    <div class="courses bg-section" style="margin-bottom: 60px;">
      <div class="container">
        <div class="row align-items-center mb-5">
          <div class="col-md-6">
            <div class="course-search">
            <form action="/courses" method="GET" class="search-form">
              <input 
                type="text" 
                name="search"
                value="<%= search %>"
                class="form-control" 
                placeholder="Search for courses..." 
              />
              <button type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            </form>
            </div>
          </div>
          <div class="col-md-6 text-md-end">
            <div class="course-sort">
            <select 
              class="form-select d-inline-block w-auto"
              onchange="location = this.value"
            >
              <option value="/courses?sort=newest" <%= sort==='newest'?'selected':'' %>>
                Newest
              </option>

              <option value="/courses?sort=priceLow" <%= sort==='priceLow'?'selected':'' %>>
                Price: Low to High
              </option>

              <option value="/courses?sort=priceHigh" <%= sort==='priceHigh'?'selected':'' %>>
                Price: High to Low
              </option>
            </select>
            </div>
          </div>
        </div>
        <div class="row">

  <% if (courses.length > 0) { %>

    <% courses.forEach(course => { %>

      <div class="col-lg-4 col-md-6 mb-4">
        <div class="course-card">

          <div class="course-image">
            <img src="/uploads/<%= course.image || 'default.jpg' %>" alt="Course" />

            <% if (course.isFeatured) { %>
              <span class="badge-featured">Featured</span>
            <% } %>

            <div class="course-overlay">
              <a href="/course/<%= course.slug %>" class="preview-btn">
                View Course
              </a>
            </div>
          </div>

          <div class="course-body">

            <div class="course-category">
              <%= course.category %>
            </div>

            <h3 class="course-title">
              <%= course.title %>
            </h3>

            <p class="course-desc">
              <%= (course.shortDescription || course.description).substring(0, 90) %>...
            </p>

            <div class="course-meta">
              <div>⏱ <%= course.duration || "N/A" %></div>
              <div>📦 <%= course.resourcesCount || 0 %> resources</div>
            </div>

<div class="course-footer">
  <div class="price">
    <span class="current">₹<%= course.offerPrice || course.price %></span>

    <% if (course.offerPrice && course.offerPrice < course.price) { %>
      <span class="old">₹<%= course.price %></span>
    <% } %>
  </div>

  <% if (course.isOwned) { %>
    <span class="text-success fw-semibold">
      ✔ You already have access to this course
    </span>
  <% } else { %>
    <a href="/course/<%= course.slug %>" class="btn-view">
      Explore
    </a>
  <% } %>
</div>

          </div>

        </div>
      </div>

    <% }) %>

  <% } else { %>

    <!-- 🔴 NO RESULTS UI -->
    <div class="col-12 text-center py-5">
      <div class="no-results-box">

        <h4 class="fw-bold mb-2">No courses found</h4>

        <% if (search) { %>
          <p class="text-muted">
            No results for "<strong><%= search %></strong>"
          </p>

          <a href="/courses" class="btn-default btn-highlighted mt-3">
            Clear Search
          </a>
        <% } else { %>
          <p class="text-muted">
            No courses available at the moment.
          </p>
        <% } %>

      </div>
    </div>

  <% } %>

</div>
        <div class="row mt-5">
          <% if (totalPages > 1) { %>
          <div class="col-lg-12">
            <nav aria-label="Page navigation">
              <ul class="pagination justify-content-center">

                <% if (currentPage > 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= currentPage - 1 %>">
                      <i class="fa-solid fa-chevron-left"></i>
                    </a>
                  </li>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                  </li>
                <% } %>

                <% if (currentPage < totalPages) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= currentPage + 1 %>">
                      <i class="fa-solid fa-chevron-right"></i>
                    </a>
                  </li>
                <% } %>

              </ul>
            </nav>
          </div>
          <% } %>
        </div>
        </div>
    </div>
    <!-- Courses Section End -->

    

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
    <!-- Main Footer Section End -->

    <!-- Mobile Bottom Navbar Start -->
    <%- include('../partials/mobileNav.ejs') %>
    <!-- Mobile Bottom Navbar End -->
    <!-- Login modal start -->
    <div class="modal fade" id="authModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content auth-modal">
          <!-- Close -->
          <button
            type="button"
            class="btn-close custom-close"
            data-bs-dismiss="modal"
          ></button>

          <div class="row g-0">
            <!-- LEFT IMAGE -->
            <div class="col-lg-6 d-none d-lg-block">
              <div class="auth-image">
                <div class="auth-overlay">
                  <h3 class="text-light mb-3">Welcome to Shony Talks</h3>
                  <p>Start your journey of transformation today.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-6 col-12">
              <div class="auth-body">
                <h4 class="mb-3">Login </h4>

                <!-- STEP 1 -->
                <form id="loginForm">
                  <div class="mb-3">
                    <input type="text" id="name" class="form-control" placeholder="Full Name" required />
                  </div>

                  <div class="mb-3">
                    <input type="email" id="email" class="form-control" placeholder="Email Address" required />
                  </div>

                  <button id="otpBtn" type="button" onclick="sendOtp()" class="btn-default btn-highlighted w-100">
                  Get OTP
                </button>
                </form>

                <!-- STEP 2 OTP -->
                <div id="otpSection" style="display: none">
                  <p class="mb-2">Enter OTP sent to your email</p>

                  <div class="otp-box mb-3">
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                  </div>

                <button id="verifyBtn" type="button" onclick="verifyOtp()" class="btn-default btn-highlighted w-100 mb-3">
                  Verify OTP
                </button>
                  <div class="text-center">
                    <a href="#" onclick="resendOtp()">Resend OTP</a>
                  </div>
                </div>

                <!-- DIVIDER -->
                <div class="auth-divider">
                  <span>OR</span>
                </div>

                <!-- GOOGLE LOGIN -->
                <a href="/auth/google" class="google-btn w-100 d-flex justify-content-center align-items-center text-decoration-none">
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                  alt=""
                />
                Continue with Google
              </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Login modal end -->

    <!-- Jquery Library File -->
    <script>
      function showTab(e, id) {
        document.querySelectorAll(".profile-tab").forEach((tab) => {
          tab.classList.add("d-none");
        });

        document.getElementById(id).classList.remove("d-none");

        document.querySelectorAll(".profile-sidebar li").forEach((li) => {
          li.classList.remove("active");
        });

        e.target.classList.add("active");
      }
    </script>
    <script src="js/jquery-3.7.1.min.js"></script>
    <!-- Circle Progress Js File -->
    <script src="js/circle-progress.min.js"></script>
    <!-- Bootstrap js file -->
    <script src="js/bootstrap.min.js"></script>
    <!-- Validator js file -->
    <script src="js/validator.min.js"></script>
    <!-- SlickNav js file -->
    <script src="js/jquery.slicknav.js"></script>
    <!-- Swiper js file -->
    <script src="js/swiper-bundle.min.js"></script>
    <!-- Counter js file -->
    <script src="js/jquery.waypoints.min.js"></script>
    <script src="js/jquery.counterup.min.js"></script>
    <!-- Magnific js file -->
    <script src="js/jquery.magnific-popup.min.js"></script>
    <!-- Parallax js -->
    <script src="js/parallaxie.js"></script>
    <!-- MagicCursor js file -->
    <script src="js/gsap.min.js"></script>
    <script src="js/magiccursor.js"></script>
    <!-- Text Effect js file -->
    <script src="js/SplitText.js"></script>
    <script src="js/ScrollTrigger.min.js"></script>
    <!-- YTPlayer js File -->
    <script src="js/jquery.mb.YTPlayer.min.js"></script>
    <!-- Wow js file -->
    <script src="js/wow.min.js"></script>
    <!-- Main Custom js file -->
    <script src="js/function.js"></script>
    <script src="js/auth.js"></script>
    <!-- toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  </body>

