    <!-- Our FAQs Section Start -->
    <div class="our-faqs">
      <div class="container">
        <div class="row">
          <div class="col-lg-6">
            <!-- FAQ Images Start -->
            <div class="faq-images">
              <!-- FAQ Image 1 Start -->
              <div class="faq-image-1">
                <figure class="image-anime reveal">
                  <img src="images/faq-1.jpg" alt="" />
                </figure>
              </div>
              <!-- FAQ Image 1 End -->

              <!-- FAQ Image 2 Start -->
              <div class="faq-image-2">
                <figure class="image-anime reveal">
                  <img src="images/faq-2.jpg" alt="" />
                </figure>
              </div>
              <!-- FAQ Image 1 End -->
            </div>
            <!-- FAQ Images End -->
          </div>

          <div class="col-lg-6">
            <!-- FAQs Content Start -->
            <div class="faqs-content">
              <!-- Section Title Start -->
              <div class="section-title">
                <h3 class="wow fadeInUp">Frequently asked questions</h3>
                <h2 class="text-anime-style-3" data-cursor="-opaque">
                  Your Questions, Answered
                </h2>
              </div>
              <!-- Section Title End -->

              <!-- FAQ Accordion Start -->
              <div class="faq-accordion" id="faqaccordion">
                <!-- FAQ Item Start -->
                <div class="accordion-item wow fadeInUp" data-wow-delay="0.2s">
                  <h2 class="accordion-header" id="heading1">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapse1"
                      aria-expanded="true"
                      aria-controls="collapse1"
                    >
                      What is Shony Talks?
                    </button>
                  </h2>
                  <div
                    id="collapse1"
                    class="accordion-collapse collapse"
                    aria-labelledby="heading1"
                    data-bs-parent="#faqaccordion"
                  >
                    <div class="accordion-body">
                      <p>
                        Shony Talks is a personal development platform that
                        focuses on transformation through structured programs,
                        mentoring, and workshops designed to support individuals
                        in achieving clarity, confidence, and growth.
                      </p>
                    </div>
                  </div>
                </div>
                <!-- FAQ Item End -->

                <!-- FAQ Item Start -->
                <div class="accordion-item wow fadeInUp" data-wow-delay="0.4s">
                  <h2 class="accordion-header" id="heading2">
                    <button
                      class="accordion-button"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapse2"
                      aria-expanded="false"
                      aria-controls="collapse2"
                    >
                      Who can benefit from these programs?
                    </button>
                  </h2>
                  <div
                    id="collapse2"
                    class="accordion-collapse collapse show"
                    aria-labelledby="heading2"
                    data-bs-parent="#faqaccordion"
                  >
                    <div class="accordion-body">
                      <p>
                        Our programs are designed for students, professionals,
                        parents, and organizations seeking meaningful growth,
                        improved mindset, and enhanced life direction.
                      </p>
                    </div>
                  </div>
                </div>
                <!-- FAQ Item End -->

                <!-- FAQ Item Start -->
                <div class="accordion-item wow fadeInUp" data-wow-delay="0.6s">
                  <h2 class="accordion-header" id="heading3">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapse3"
                      aria-expanded="false"
                      aria-controls="collapse3"
                    >
                      How can I enroll in a program?
                    </button>
                  </h2>
                  <div
                    id="collapse3"
                    class="accordion-collapse collapse"
                    aria-labelledby="heading3"
                    data-bs-parent="#faqaccordion"
                  >
                    <div class="accordion-body">
                      <p>
                        You can enroll by contacting us through the website or
                        WhatsApp. Our team will guide you through the available
                        programs and assist with the registration process.
                      </p>
                    </div>
                  </div>
                </div>
                <!-- FAQ Item End -->

                <!-- FAQ Item Start -->
                <div class="accordion-item wow fadeInUp" data-wow-delay="0.8s">
                  <h2 class="accordion-header" id="heading4">
                    <button
                      class="accordion-button collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapse4"
                      aria-expanded="false"
                      aria-controls="collapse4"
                    >
                      Are sessions conducted online or offline?
                    </button>
                  </h2>
                  <div
                    id="collapse4"
                    class="accordion-collapse collapse"
                    aria-labelledby="heading4"
                    data-bs-parent="#faqaccordion"
                  >
                    <div class="accordion-body">
                      <p>
                        We offer both online and offline sessions depending on
                        the nature of the program and participant preference.
                      </p>
                    </div>
                  </div>
                </div>
                <!-- FAQ Item End -->
              </div>
              <!-- FAQ Accordion End -->
            </div>
            <!-- FAQs Content End -->
          </div>
        </div>
      </div>
    </div>
    <!-- Our FAQs Section End -->

    <!-- Our Testimonial Section Start-->
    <div class="our-testimonial bg-section">
      <div class="container">
        <div class="row">
          <div class="col-lg-6">
            <div class="testimonial-content">
              <div class="section-title">
                <h3 class="wow fadeInUp">Testimonials</h3>
                <h2 class="text-anime-style-3" data-cursor="-opaque">
                  Stories of Transformation
                </h2>
              </div>
              <div class="testimonial-boxes">
                <% if (testimonials && testimonials.length > 0) { %>
                  <% testimonials.forEach((item, index) => { %>
                    <% if (item.isActive) { %>
                      <div
                        class="testimonial-item <%= index === 0 ? 'active' : '' %> wow fadeInUp"
                        data-wow-delay="<%= (index * 0.2) %>s"
                      >
                        <div class="testimonial-item-content">
                          <div class="testimonial-rating">
                            <% for(let i = 0; i < 5; i++) { %>
                              <i class="<%= i < item.rating ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                            <% } %>
                          </div>
                          <div class="testimonial-info">
                            <p>“<%= item.content %>”</p>
                          </div>
                        </div>
                        <div class="testimonial-author-box">
                          <div class="testimonial-author-iamge">
                            <figure class="image-anime">
                              <img src="/uploads/<%= item.imageUrl %>" alt="<%= item.name %>" />
                            </figure>
                          </div>
                          <div class="testimonial-author-content">
                            <h3><%= item.name %></h3>
                            <p><%= item.designation %></p>
                          </div>
                        </div>
                        </div>
                      <% } %>
                  <% }) %>
                <% } else { %>
                  <p>No testimonials available at the moment.</p>
                <% } %>
              </div>
              </div>
            </div>

          <div class="col-lg-6">
            <div class="testimonial-images">
              <div class="testimonial-img-1">
                <figure class="image-anime">
                  <img src="images/test-1.jpg" alt="" />
                </figure>
              </div>
              <div class="testimonial-img-2">
                <figure class="image-anime">
                  <img src="images/test-2.jpg" alt="" />
                </figure>
              </div>
            </div>
            </div>
        </div>
      </div>
    </div>
    <!-- Our Testimonial Section End-->

    <!-- Our Blog Section Start -->
    <div class="our-blog">
      <div class="container">
        <div class="row section-row align-items-center">
          <div class="col-lg-6">
            <div class="section-title">
              <h3 class="wow fadeInUp">Our Blog</h3>
              <h2 class="text-anime-style-3" data-cursor="-opaque">
                Real Talks on Life & Transformation
              </h2>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
              <a href="/blogs" class="btn-default">view all blogs</a>
            </div>
          </div>
        </div>

        <div class="row">
          <% if (blogs && blogs.length > 0) { %>
            <% blogs.forEach((post, index) => { %>
              <div class="col-lg-4 col-md-6">
                <div class="post-item wow fadeInUp" data-wow-delay="<%= (index * 0.2) %>s">
                  <div class="post-featured-image">
                    <a href="/blog/<%= post.slug %>" data-cursor-text="View">
                      <figure class="image-anime">
                        <% if (post.featuredImage) { %>
                          <img src="<%= post.featuredImage %>" alt="<%= post.title %>" />
                        <% } else { %>
                          <img src="images/faq-1.jpg" alt="Default Blog Image" />
                        <% } %>
                      </figure>
                    </a>
                  </div>

                  <div class="post-item-body">
                    <div class="post-item-content">
                      <div class="post-meta mb-2">
                        <small class="text-primary text-uppercase font-weight-bold"><%= post.category || 'General' %></small>
                        <small class="ms-2 text-muted">| <%= post.formattedDate %></small>
                      </div>
                      
                      <h3>
                        <a href="/blog/<%= post.slug %>">
                          <%= post.title %>
                        </a>
                      </h3>
                    </div>

                    <div class="post-item-btn">
                      <a href="/blog/<%= post.slug %>" class="readmore-btn">read more</a>
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
          <% } else { %>
            <div class="col-12 text-center">
              <p>Stay tuned! Inspiring stories are on their way.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
    <!-- Our Blog Section End -->

