    <!-- Our Programs Section Start -->
    <div class="our-programs">
      <div class="container">
        <div class="row section-row align-items-center">
          <div class="col-lg-6">
            <div class="section-title">
              <h3 class="wow fadeInUp">our programs</h3>
              <h2 class="text-anime-style-3" data-cursor="-opaque">
                Transformative Programs for a New You
              </h2>
            </div>
            </div>

          <div class="col-lg-6">
            <div class="section-btn wow fadeInUp" data-wow-delay="0.2s">
              <a href="/programs" class="btn-default">all programs</a>
            </div>
            </div>
        </div>

        <div class="row">
          <% if (programs && programs.length > 0) { %>
            <% programs.forEach((program, index) => { %>
              <div class="col-lg-4 col-md-6">
                <div class="program-item wow fadeInUp" data-wow-delay="<%= (index * 0.2) %>s">
                  <div class="program-image">
                    <a href="/program/<%= program.slug %>" data-cursor-text="View">
                      <figure class="image-anime">
                        <img src="/uploads/<%= program.image %>" alt="<%= program.title %>" />
                      </figure>
                    </a>
                  </div>
                  <div class="program-body">
                    <div class="program-content">
                      <h3>
                        <a href="/program/<%= program.slug %>"><%= program.title %></a>
                      </h3>
                      <% if (program.shortDescription) { %>
                        <p class="mt-2 text-muted prgrm-desc"><%= program.shortDescription %></p>
                      <% } %>
                    </div>
                    <div class="program-readmore-btn">
                      <a href="/program/<%= program.slug %>" class="btn-default btn-highlighted">read more</a>
                    </div>
                    </div>
                  </div>
                </div>
            <% }) %>
          <% } else { %>
            <div class="col-12 text-center">
              <p>No programs are currently scheduled. Check back soon for new opportunities!</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
    <!-- Our Programs Section End -->

