    <!-- toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
      let currentStep = 0;

      function moveSlider(direction) {
        const track = document.getElementById('sliderTrack');
        const cards = document.querySelectorAll('.slider-card');
        if (!cards.length) return;

        const totalCards = cards.length;
        
        // 1. Calculate how many cards are visible based on current screen width
        const viewportWidth = document.querySelector('.slider-viewport').offsetWidth;
        const cardWidthWithGap = cards[0].offsetWidth + 15; // 15 is the CSS gap
        const visibleCards = Math.round(viewportWidth / cardWidthWithGap);
        
        // 2. Set max steps based on responsive visibility
        const maxSteps = totalCards - visibleCards;

        currentStep += direction;

        // 3. Boundary Checks
        if (currentStep < 0) {
          currentStep = 0;
        } else if (currentStep > maxSteps) {
          currentStep = maxSteps;
        }

        // 4. Smooth Move
        const moveAmount = currentStep * cardWidthWithGap;
        track.style.transform = `translateX(-${moveAmount}px)`;
        
        // 5. Optional: Fade buttons when reaching start/end
        document.querySelector('.prev-btn').style.opacity = currentStep === 0 ? "0.3" : "1";
        document.querySelector('.next-btn').style.opacity = currentStep >= maxSteps ? "0.3" : "1";
      }

      // Reset position on window resize to prevent alignment bugs
      window.addEventListener('resize', () => {
        currentStep = 0;
        document.getElementById('sliderTrack').style.transform = `translateX(0px)`;
      });

      function openImageModal(imgSrc) {
        // Set the source of the image inside the modal
        const modalImg = document.getElementById('modalPreviewImage');
        modalImg.src = imgSrc;
        
        // Trigger the Bootstrap Modal
        const imageModal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
        imageModal.show();
      }
    </script>
