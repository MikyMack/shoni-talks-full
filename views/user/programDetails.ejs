<!doctype html>
<html lang="zxx">
  <!-- Mirrored from html.awaikenthemes.com/healix/program-single.html by HTTrack Website Copier/3.x [XR&CO'2014], Tue, 14 Apr 2026 07:36:02 GMT -->
  <head>
    <!-- Meta -->
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1"
    />
    <meta name="description" content="" />
    <meta name="keywords" content="" />
    <meta name="author" content="Awaiken" />
    <!-- Page Title -->
    <title>Shony Talks - Program Details</title>
    <!-- Favicon Icon -->
    <link rel="shortcut icon" type="image/x-icon" href="images/favicon.png" />
    <!-- Google Fonts Css-->
    <link rel="preconnect" href="https://fonts.googleapis.com/" />
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;family=Epilogue:ital,wght@0,100..900;1,100..900&amp;display=swap"
      rel="stylesheet"
    />
    <!-- Bootstrap Css -->
    <link href="/css/bootstrap.min.css" rel="stylesheet" media="screen" />
    <!-- SlickNav Css -->
    <link href="/css/slicknav.min.css" rel="stylesheet" />
    <!-- Swiper Css -->
    <link rel="stylesheet" href="/css/swiper-bundle.min.css" />
    <!-- Font Awesome Icon Css-->
    <link href="/css/all.min.css" rel="stylesheet" media="screen" />
    <!-- Animated Css -->
    <link href="/css/animate.css" rel="stylesheet" />
    <!-- Magnific Popup Core Css File -->
    <link rel="stylesheet" href="/css/magnific-popup.css" />
    <!-- Mouse Cursor Css File -->
    <link rel="stylesheet" href="/css/mousecursor.css" />
    <!-- Main Custom Css -->
    <link href="/css/custom.css" rel="stylesheet" media="screen" />

      <!-- toastify CSS -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  </head>
  <body>
   
    <!-- Floating Icon Start-->
    <%- include('../partials/floatingIcons.ejs') %>
    <!-- Floating Icon End -->
    <!-- Header Start -->
	  <%- include('../partials/header.ejs') %>
    <!-- Header End -->

    <!-- Page Header Start -->
    <div class="page-header bg-section dark-section">
      <div class="container">
        <div class="row">
          <div class="col-lg-12">

            <div class="page-header-box">

              <!-- TITLE -->
              <h1 class="text-anime-style-3" data-cursor="-opaque">
                <%= program.title %>
              </h1>

              <!-- BREADCRUMB -->
              <nav class="wow fadeInUp">
                <ol class="breadcrumb">

                  <li class="breadcrumb-item">
                    <a href="/">Home</a>
                  </li>

                  <li class="breadcrumb-item">
                    <a href="/programs">Programs</a>
                  </li>

                  <li class="breadcrumb-item active" aria-current="page">
                    <%= program.title %>
                  </li>

                </ol>
              </nav>

            </div>

          </div>
        </div>
      </div>
    </div>
    <!-- Page Header End -->

    <!-- Page Program Single Start -->
    <div class="page-program-single">
      <div class="container">
        <div class="row">
          <div class="col-lg-4">
            <!-- Page Single Sidebar Start -->
            <div class="page-single-sidebar">
              <!-- Program Detail Box Start -->
              <div class="program-detail-box wow fadeInUp">
                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Program name</h3>
                  <p><%= program.title %></p>
                </div>
                <!-- Case Study Detail Item End -->

                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Start date</h3>
                  <p><%= schedule ? new Date(schedule.startDate).toDateString() : "Not available" %></p>
                </div>
                <!-- Case Study Detail Item End -->

                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Location</h3>
                  <p><%= schedule?.location || "Not specified" %></p>
                </div>
                <!-- Case Study Detail Item End -->

                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Program duration</h3>
                  <p><%= program.duration || "N/A" %></p>
                </div>

                <a href="<%= schedule?.joinLink || 'https://wa.me/919744975574' %>" target="_blank" class="btn-default btn-highlighted">JOIN NOW</a>

                <!-- Case Study Detail Item End -->
              </div>
              <!-- Program Detail Box End -->

              <!-- Sidebar CTA Box Start -->
              <div
                class="page-cta-box sidebar-cta-box wow fadeInUp d-none d-md-block"
                data-wow-delay="0.25s"
              >
                <!-- Service Content Info Start -->
                <div class="page-cta-box-info">
                  <h3>Have You any question</h3>
                  <h2>Don't waste your time call us!</h2>
                </div>
                <!-- Service Content Info End -->

                <!-- Contact Now Box Start -->
                <div class="contact-now-box">
                  <div class="icon-box">
                    <img src="images/icon-phone.svg" alt="" />
                  </div>
                  <div class="contact-now-box-content">
                    <p>contact today!</p>
                    <h3><a href="tel:+919744975574">+91 9744 975 574</a></h3>
                  </div>
                </div>
                <!-- Contact Now Box End -->
              </div>
              <!-- Sidebar CTA Box End -->
            </div>
            <!-- Page Single Sidebar End -->
          </div>

          <div class="col-lg-8">
            <!-- Program Single Content Start -->
            <div class="program-single-content">
              <!-- Program Featured Image Start -->
              <div class="program-featured-image">
                <figure class="image-anime reveal">
                  <img src="/uploads/<%= program.image %>" alt="<%= program.title %>">
                </figure>
              </div>
              <!-- Program Featured Image End -->

              <!-- Program Entry Start -->
              <div class="program-entry">
                <p class="wow fadeInUp"><%= program.description %>
                </p>

                  <% if (program.features && program.features.length > 0) { %>
                  <ul>
                    <% program.features.forEach(f => { %>
                      <li><%= f %></li>
                    <% }) %>
                  </ul>
                  <% } %>

                <!-- Program Entry Image Video Start -->
                <div class="program-entry-image-video">
                  <div class="program-entry-image">
                    <figure class="image-anime reveal">
                      <% if (program.gallery && program.gallery.length > 0) { %>
                        <img src="/uploads/<%= program.gallery[0] %>" alt="">
                      <% } else { %>
                        <img src="/uploads/<%= program.image %>" alt="">
                      <% } %>
                    </figure>
                  </div>

                 
                </div>
                <!-- Program Entry Image Video End -->

                <!-- Program Entry Practices Start -->
                <div class="program-entry-practices">
                  <h2 class="text-anime-style-3">
                    <%= program.subtitle || "Program Highlights" %>
                  </h2>
                  <p class="wow fadeInUp">
                    <%= program.shortDescription || program.description %>
                  </p>
                  <!-- Program Image Content Start -->
                  <div class="program-image-content-box">
                    <!-- Program Content List Start -->
                    <div class="what-we-do-list program-content-list">

                      <% if (program.features && program.features.length > 0) { %>
                        <% program.features.forEach((feature, index) => { %>

                          <div class="what-we-list-item wow fadeInUp" data-wow-delay="0.<%= index + 2 %>s">

                            <div class="icon-box">
                              <img src="/images/icon-service-<%= (index % 5) + 1 %>.svg" alt="">
                            </div>

                            <div class="what-we-do-list-content">
                              <h3><%= feature %></h3>
                              <p>Enhance your experience with <%= feature.toLowerCase() %>.</p>
                            </div>

                          </div>

                        <% }) %>
                      <% } %>

                    </div>
                    <!-- Program Content List End -->

                    <!-- Program Practice Image Start -->
                    <!-- <div class="program-practice-image">
                      <figure class="image-anime reveal">
                        <img src="images/programs/program6.jpg" alt="" />
                      </figure>
                    </div> -->
                    <!-- Program Practice Image End -->
                  </div>
                  <!-- Program Image Content End -->
                </div>
                <!-- Program Entry Practices End -->
              </div>
              <!-- Program Entry End -->

            </div>
            <!-- Program Single Content End -->
          </div>
        </div>
      </div>
    </div>
    <!-- Page Program Single End -->

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
    <!-- Main Footer Section End -->

     <!-- Login modal start -->
    <div class="modal fade" id="authModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content auth-modal">
          <!-- Close -->
          <button
            type="button"
            class="btn-close custom-close"
            data-bs-dismiss="modal"
          ></button>

          <div class="row g-0">
            <!-- LEFT IMAGE -->
            <div class="col-lg-6 d-none d-lg-block">
              <div class="auth-image">
                <div class="auth-overlay">
                  <h3 class="text-light mb-3">Welcome to Shony Talks</h3>
                  <p>Start your journey of transformation today.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-6 col-12">
              <div class="auth-body">
                <h4 class="mb-3">Login </h4>

                <!-- STEP 1 -->
                <form id="loginForm">
                  <div class="mb-3">
                    <input type="text" id="name" class="form-control" placeholder="Full Name" required />
                  </div>

                  <div class="mb-3">
                    <input type="email" id="email" class="form-control" placeholder="Email Address" required />
                  </div>

                  <button id="otpBtn" type="button" onclick="sendOtp()" class="btn-default btn-highlighted w-100">
                  Get OTP
                </button>
                </form>

                <!-- STEP 2 OTP -->
                <div id="otpSection" style="display: none">
                  <p class="mb-2">Enter OTP sent to your email</p>

                  <div class="otp-box mb-3">
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                  </div>

                <button id="verifyBtn" type="button" onclick="verifyOtp()" class="btn-default btn-highlighted w-100 mb-3">
                  Verify OTP
                </button>
                  <div class="text-center">
                    <a href="#" onclick="resendOtp()">Resend OTP</a>
                  </div>
                </div>

                <!-- DIVIDER -->
                <div class="auth-divider">
                  <span>OR</span>
                </div>

                <!-- GOOGLE LOGIN -->
                <button class="google-btn w-100">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                    alt=""
                  />
                  Continue with Google
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Login modal end -->

    <!-- Mobile Bottom Navbar Start -->
    <%- include('../partials/mobileNav.ejs') %>
    <!-- Mobile Bottom Navbar End -->

    <!-- Jquery Library File -->
    <script src="/js/jquery-3.7.1.min.js"></script>
    <!-- Circle Progress Js File -->
    <script src="/js/circle-progress.min.js"></script>
    <!-- Bootstrap js file -->
    <script src="/js/bootstrap.min.js"></script>
    <!-- Validator js file -->
    <script src="/js/validator.min.js"></script>
    <!-- SlickNav js file -->
    <script src="/js/jquery.slicknav.js"></script>
    <!-- Swiper js file -->
    <script src="/js/swiper-bundle.min.js"></script>
    <!-- Counter js file -->
    <script src="/js/jquery.waypoints.min.js"></script>
    <script src="/js/jquery.counterup.min.js"></script>
    <!-- Magnific js file -->
    <script src="/js/jquery.magnific-popup.min.js"></script>
    <!-- Parallax js -->
    <script src="/js/parallaxie.js"></script>
    <!-- MagicCursor js file -->
    <script src="/js/gsap.min.js"></script>
    <script src="/js/magiccursor.js"></script>
    <!-- Text Effect js file -->
    <script src="/js/SplitText.js"></script>
    <script src="/js/ScrollTrigger.min.js"></script>
    <!-- YTPlayer js File -->
    <script src="/js/jquery.mb.YTPlayer.min.js"></script>
    <!-- Wow js file -->
    <script src="/js/wow.min.js"></script>
    <!-- Main Custom js file -->
    <script src="/js/function.js"></script>
    <script src="js/auth.js"></script>
    <!-- toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  </body>

