    <!-- Page Program Single Start -->
    <div class="page-program-single">
      <div class="container">
        <div class="row">
          <div class="col-lg-4">
            <!-- Page Single Sidebar Start -->
            <div class="page-single-sidebar">
              <!-- Program Detail Box Start -->
              <div class="program-detail-box wow fadeInUp">
                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Program name</h3>
                  <p><%= program.title %></p>
                </div>
                <!-- Case Study Detail Item End -->

                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Start date</h3>
                  <p><%= schedule ? new Date(schedule.startDate).toDateString() : "Not available" %></p>
                </div>
                <!-- Case Study Detail Item End -->

                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Location</h3>
                  <p><%= schedule?.location || "Not specified" %></p>
                </div>
                <!-- Case Study Detail Item End -->

                <!-- Case Study Detail Item Start -->
                <div class="program-detail-item">
                  <h3>Program duration</h3>
                  <p><%= program.duration || "N/A" %></p>
                </div>

                <a href="<%= schedule?.joinLink || '#' %>" class="btn-default btn-highlighted">JOIN NOW</a>

                <!-- Case Study Detail Item End -->
              </div>
              <!-- Program Detail Box End -->

              <!-- Sidebar CTA Box Start -->
              <div
                class="page-cta-box sidebar-cta-box wow fadeInUp d-none d-md-block"
                data-wow-delay="0.25s"
              >
                <!-- Service Content Info Start -->
                <div class="page-cta-box-info">
                  <h3>Have You any question</h3>
                  <h2>Don't waste your time call us!</h2>
                </div>
                <!-- Service Content Info End -->

                <!-- Contact Now Box Start -->
                <div class="contact-now-box">
                  <div class="icon-box">
                    <img src="images/icon-phone.svg" alt="" />
                  </div>
                  <div class="contact-now-box-content">
                    <p>contact today!</p>
                    <h3><a href="tel:+919744975574">+91 9744 975 574</a></h3>
                  </div>
                </div>
                <!-- Contact Now Box End -->
              </div>
              <!-- Sidebar CTA Box End -->
            </div>
            <!-- Page Single Sidebar End -->
          </div>

          <div class="col-lg-8">
            <!-- Program Single Content Start -->
            <div class="program-single-content">
              <!-- Program Featured Image Start -->
              <div class="program-featured-image">
                <figure class="image-anime reveal">
                  <img src="/uploads/<%= program.image %>" alt="<%= program.title %>">
                </figure>
              </div>
              <!-- Program Featured Image End -->

              <!-- Program Entry Start -->
              <div class="program-entry">
                <p class="wow fadeInUp"><%= program.description %>
                </p>

                  <% if (program.features && program.features.length > 0) { %>
                  <ul>
                    <% program.features.forEach(f => { %>
                      <li><%= f %></li>
                    <% }) %>
                  </ul>
                  <% } %>

                <!-- Program Entry Image Video Start -->
                <div class="program-entry-image-video">
                  <div class="slider-wrapper">
                    <button class="slider-btn prev-btn" onclick="moveSlider(-1)">&#10094;</button>
                    
                    <div class="slider-viewport">
                      <div class="slider-track" id="sliderTrack">
                        <% if (program.gallery && program.gallery.length > 0) { %>
                          <% program.gallery.forEach(function(img) { %>
                            <div class="slider-card" onclick="openImageModal('/uploads/<%= img %>')" style="cursor: pointer;">
                              <img src="/uploads/<%= img %>" alt="Gallery Image">
                            </div>
                          <% }); %>
                        <% } else { %>
                          <div class="no-image">No images available</div>
                        <% } %>
                      </div>
                    </div>

                    <button class="slider-btn next-btn" onclick="moveSlider(1)">&#10095;</button>
                  </div>
                </div>
                <!-- Program Entry Image Video End -->

                <!-- Program Entry Practices Start -->
                <div class="program-entry-practices">
                  <h2 class="text-anime-style-3">
                    <%= program.subtitle || "Program Highlights" %>
                  </h2>
                  <p class="wow fadeInUp">
                    <%= program.shortDescription || program.description %>
                  </p>
                  <!-- Program Image Content Start -->
                  <div class="program-image-content-box">
                    <!-- Program Content List Start -->
                    <div class="what-we-do-list program-content-list">

                      <% if (program.features && program.features.length > 0) { %>
                        <% program.features.forEach((feature, index) => { %>

                          <div class="what-we-list-item wow fadeInUp" data-wow-delay="0.<%= index + 2 %>s">

                            <div class="icon-box">
                              <img src="/images/icon-service-<%= (index % 5) + 1 %>.svg" alt="">
                            </div>

                            <div class="what-we-do-list-content">
                              <h3><%= feature %></h3>
                              <p>Enhance your experience with <%= feature.toLowerCase() %>.</p>
                            </div>

                          </div>

                        <% }) %>
                      <% } %>

                    </div>
                    <!-- Program Content List End -->

                    <!-- Program Practice Image Start -->
                    <!-- <div class="program-practice-image">
                      <figure class="image-anime reveal">
                        <img src="images/programs/program6.jpg" alt="" />
                      </figure>
                    </div> -->
                    <!-- Program Practice Image End -->
                  </div>
                  <!-- Program Image Content End -->
                </div>
                <!-- Program Entry Practices End -->
              </div>
              <!-- Program Entry End -->

            </div>
            <!-- Program Single Content End -->
          </div>
        </div>
      </div>
    </div>
    <!-- Page Program Single End -->

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
