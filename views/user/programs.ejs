<!DOCTYPE html>
<html lang="zxx">

<!-- Mirrored from html.awaikenthemes.com/healix/programs.html by HTTrack Website Copier/3.x [XR&CO'2014], Tue, 14 Apr 2026 07:36:01 GMT -->
<head>
	<!-- Meta -->
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
	<meta name="description" content="">
	<meta name="keywords" content="">
	<meta name="author" content="Awaiken">
	<!-- Page Title -->
    <title>Shony Talks - Programs</title>
	<!-- Favicon Icon -->
	<link rel="shortcut icon" type="image/x-icon" href="images/favicon.png">
	<!-- Google Fonts Css-->
	<link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&amp;family=Epilogue:ital,wght@0,100..900;1,100..900&amp;display=swap" rel="stylesheet">
	<!-- Bootstrap Css -->
	<link href="css/bootstrap.min.css" rel="stylesheet" media="screen">
	<!-- SlickNav Css -->
	<link href="css/slicknav.min.css" rel="stylesheet">
	<!-- Swiper Css -->
	<link rel="stylesheet" href="css/swiper-bundle.min.css">
	<!-- Font Awesome Icon Css-->
	<link href="css/all.min.css" rel="stylesheet" media="screen">
	<!-- Animated Css -->
	<link href="css/animate.css" rel="stylesheet">
    <!-- Magnific Popup Core Css File -->
	<link rel="stylesheet" href="css/magnific-popup.css">
	<!-- Mouse Cursor Css File -->
	<link rel="stylesheet" href="css/mousecursor.css">
	<!-- Main Custom Css -->
	<link href="css/custom.css" rel="stylesheet" media="screen">
    <!-- toastify CSS -->
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>
<body>

    <!-- Floating Icon Start-->
    <%- include('../partials/floatingIcons.ejs') %>
    <!-- Floating Icon End -->  

    <!-- Header Start -->
	  <%- include('../partials/header.ejs') %>
	<!-- Header End -->

    <!-- Page Header Start -->
    <div class="page-header bg-section dark-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <!-- Page Header Box Start -->
                    <div class="page-header-box">
                        <h1 class="text-anime-style-3" data-cursor="-opaque">Our Programs</h1>
                        <nav class="wow fadeInUp">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/">home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Programs</li>
                            </ol>
                        </nav>
                    </div>
                    <!-- Page Header Box End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End -->

    <!-- Programs Section Start -->
    <div class="page-programs">
        <div class="container">
            <div class="row">
                <% if (programs.length > 0) { %>
                  <% programs.forEach(program => { %>

                    <div class="col-lg-4 col-md-6">
                      <div class="program-item wow fadeInUp">

                        <div class="program-image">
                          <a href="/program/<%= program.slug %>" data-cursor-text="View">
                            <figure class="image-anime">
                              <img src="/uploads/<%= program.image %>" alt="<%= program.title %>">
                            </figure>
                          </a>
                        </div>

                        <div class="program-body">
                          <div class="program-content">
                            <h3>
                              <a href="/program/<%= program.slug %>">
                                <%= program.title %>
                              </a>
                            </h3>

                            <% if (program.shortDescription) { %>
                              <p class="text-light"><%= program.shortDescription %></p>
                            <% } %>

                          </div>

                          <div class="program-readmore-btn">
                            <a href="/program/<%= program.slug %>" class="btn-default btn-highlighted">
                              Read More
                            </a>
                          </div>
                        </div>

                      </div>
                    </div>

                  <% }) %>
                <% } else { %>
                  <p>No programs available</p>
                <% } %>

                </div>

              <% if (totalPages > 1) { %>
              <div class="col-lg-12">
                <div class="page-pagination">
                  <ul class="pagination">

                    <!-- Prev -->
                    <% if (currentPage > 1) { %>
                      <li>
                        <a href="?page=<%= currentPage - 1 %>">
                          <i class="fa-solid fa-arrow-left-long"></i>
                        </a>
                      </li>
                    <% } %>

                    <!-- Numbers -->
                    <% for (let i = 1; i <= totalPages; i++) { %>
                      <li class="<%= currentPage === i ? 'active' : '' %>">
                        <a href="?page=<%= i %>"><%= i %></a>
                      </li>
                    <% } %>

                    <!-- Next -->
                    <% if (currentPage < totalPages) { %>
                      <li>
                        <a href="?page=<%= currentPage + 1 %>">
                          <i class="fa-solid fa-arrow-right-long"></i>
                        </a>
                      </li>
                    <% } %>

                  </ul>
                </div>
              </div>
              <% } %> 
            </div>
        </div>
    </div>
    <!-- Program Section End -->

    <!-- Main Footer Section Start -->
    <%- include('../partials/footer.ejs') %>
    <!-- Main Footer Section End -->

     <!-- Login modal start -->
   <div class="modal fade" id="authModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content auth-modal">
          <!-- Close -->
          <button
            type="button"
            class="btn-close custom-close"
            data-bs-dismiss="modal"
          ></button>

          <div class="row g-0">
            <!-- LEFT IMAGE -->
            <div class="col-lg-6 d-none d-lg-block">
              <div class="auth-image">
                <div class="auth-overlay">
                  <h3 class="text-light mb-3">Welcome to Shony Talks</h3>
                  <p>Start your journey of transformation today.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-6 col-12">
              <div class="auth-body">
                <h4 class="mb-3">Login </h4>

                <!-- STEP 1 -->
                <form id="loginForm">
                  <div class="mb-3">
                    <input type="text" id="name" class="form-control" placeholder="Full Name" required />
                  </div>

                  <div class="mb-3">
                    <input type="email" id="email" class="form-control" placeholder="Email Address" required />
                  </div>

                  <button id="otpBtn" type="button" onclick="sendOtp()" class="btn-default btn-highlighted w-100">
                  Get OTP
                </button>
                </form>

                <!-- STEP 2 OTP -->
                <div id="otpSection" style="display: none">
                  <p class="mb-2">Enter OTP sent to your email</p>

                  <div class="otp-box mb-3">
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                    <input type="text" maxlength="1" class="otp-input" />
                  </div>

                <button id="verifyBtn" type="button" onclick="verifyOtp()" class="btn-default btn-highlighted w-100 mb-3">
                  Verify OTP
                </button>
                  <div class="text-center">
                    <a href="#" onclick="resendOtp()">Resend OTP</a>
                  </div>
                </div>

                <!-- DIVIDER -->
                <div class="auth-divider">
                  <span>OR</span>
                </div>

                <!-- GOOGLE LOGIN -->
                <a href="/auth/google" class="google-btn w-100 d-flex justify-content-center align-items-center text-decoration-none">
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                  alt=""
                />
                Continue with Google
              </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Login modal end -->

    <!-- Mobile Bottom Navbar Start -->
    <%- include('../partials/mobileNav.ejs') %>
    <!-- Mobile Bottom Navbar End -->

    <!-- Jquery Library File -->
    <script src="js/jquery-3.7.1.min.js"></script>
    <!-- Circle Progress Js File -->
    <script src="js/circle-progress.min.js"></script>
    <!-- Bootstrap js file -->
    <script src="js/bootstrap.min.js"></script>
    <!-- Validator js file -->
    <script src="js/validator.min.js"></script>
    <!-- SlickNav js file -->
    <script src="js/jquery.slicknav.js"></script>
    <!-- Swiper js file -->
    <script src="js/swiper-bundle.min.js"></script>
    <!-- Counter js file -->
    <script src="js/jquery.waypoints.min.js"></script>
    <script src="js/jquery.counterup.min.js"></script>
    <!-- Magnific js file -->
    <script src="js/jquery.magnific-popup.min.js"></script>
    <!-- Parallax js -->
    <script src="js/parallaxie.js"></script>
    <!-- MagicCursor js file -->
    <script src="js/gsap.min.js"></script>
    <script src="js/magiccursor.js"></script>
    <!-- Text Effect js file -->
    <script src="js/SplitText.js"></script>
    <script src="js/ScrollTrigger.min.js"></script>
    <!-- YTPlayer js File -->
    <script src="js/jquery.mb.YTPlayer.min.js"></script>
    <!-- Wow js file -->
    <script src="js/wow.min.js"></script>
    <!-- Main Custom js file -->
    <script src="js/function.js"></script>
    <script src="js/auth.js"></script>
    <!-- toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</body>

