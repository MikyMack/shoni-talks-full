    <!-- Why Choose Us Sevtion Start -->
    <div class="why-choose-us bg-section dark-section">
        <div class="container">
            <div class="row section-row align-items-center">
                <div class="col-lg-6">
                    <!-- Section Title Start -->
                    <div class="section-title">
                        <h3 class="wow fadeInUp">Our Journey</h3>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">The Path to Transformation</h2>
                    </div>
                    <!-- Section Title End -->
                </div>
                
                <div class="col-lg-6">
                    <!-- Section Title Content Start -->
                    <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
                        <p>From a vision of youth empowerment to a global platform for mental wellness, discover the milestones that shaped our mission to help individuals reclaim their inner strength.</p>
                    </div>
                    <!-- Section Title Content End -->
                </div>
            </div>

            <div class="row align-items-center">
                <div class="col-lg-12">
                    <div class="journey-wrapper">
                        <p class="journey-intro wow fadeInUp">A journey built on the belief that true change begins within.</p>
                        
                        <div class="journey-item wow fadeInUp" data-wow-delay="0.2s">
                            <div class="journey-number">1</div>
                            <div class="journey-content">
                                <h3>The Beginning</h3>
                                <p>Shony Talks started with a simple vision—to help individuals understand their thoughts, overcome inner challenges, and take control of their lives.</p>
                            </div>
                        </div>

                        <div class="journey-item wow fadeInUp" data-wow-delay="0.4s">
                            <div class="journey-number">2</div>
                            <div class="journey-content">
                                <h3>Creating Meaningful Change</h3>
                                <p>By combining practical guidance, behavioral understanding, and consistent support, we began helping people build clarity, confidence, and emotional strength.</p>
                            </div>
                        </div>

                        <div class="journey-item wow fadeInUp" data-wow-delay="0.6s">
                            <div class="journey-number">3</div>
                            <div class="journey-content">
                                <h3>Continuing the Impact</h3>
                                <p>Today, we continue to empower individuals and families to create lasting transformation and live with purpose, balance, and confidence.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Why Choose Us Sevtion End -->

    <!-- Our Testimonial Section Start-->
    <div class="our-testimonial bg-section">
      <div class="container">
        <div class="row">
          <div class="col-lg-6">
            <div class="testimonial-content">
              <div class="section-title">
                <h3 class="wow fadeInUp">Testimonials</h3>
                <h2 class="text-anime-style-3" data-cursor="-opaque">
                  Stories of Transformation
                </h2>
              </div>
              <div class="testimonial-boxes">
                <% if (testimonials && testimonials.length > 0) { %>
                  <% testimonials.forEach((item, index) => { %>
                    <% if (item.isActive) { %>
                      <div
                        class="testimonial-item <%= index === 0 ? 'active' : '' %> wow fadeInUp"
                        data-wow-delay="<%= (index * 0.2) %>s"
                      >
                        <div class="testimonial-item-content">
                          <div class="testimonial-rating">
                            <% for(let i = 0; i < 5; i++) { %>
                              <i class="<%= i < item.rating ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                            <% } %>
                          </div>
                          <div class="testimonial-info">
                            <p>“<%= item.content %>”</p>
                          </div>
                        </div>
                        <div class="testimonial-author-box">
                          <div class="testimonial-author-iamge">
                            <figure class="image-anime">
                              <img src="/uploads/<%= item.imageUrl %>" alt="<%= item.name %>" />
                            </figure>
                          </div>
                          <div class="testimonial-author-content">
                            <h3><%= item.name %></h3>
                            <p><%= item.designation %></p>
                          </div>
                        </div>
                        </div>
                      <% } %>
                  <% }) %>
                <% } else { %>
                  <p>No testimonials available at the moment.</p>
                <% } %>
              </div>
              </div>
            </div>

          <div class="col-lg-6">
            <div class="testimonial-images">
              <div class="testimonial-img-1">
                <figure class="image-anime">
                  <img src="images/test-1.jpg" alt="" />
                </figure>
              </div>
              <div class="testimonial-img-2">
                <figure class="image-anime">
                  <img src="images/test-2.jpg" alt="" />
                </figure>
              </div>
            </div>
            </div>
        </div>
      </div>
    </div>
